/* pages/chat-list/chat-list.wxss */
.container {
  background: #f5f5f5;
  min-height: 100vh;
}
.conv-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.conv-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 20rpx;
}
.conv-info {
  flex: 1;
}
.conv-name {
  font-size: 32rpx;
  font-weight: bold;
}
.conv-lastmsg {
  color: #888;
  font-size: 26rpx;
  margin-top: 10rpx;
}
.unread-badge {
  background: #e74c3c;
  color: #fff;
  border-radius: 50%;
  width: 40rpx;
  height: 40rpx;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}
.empty {
  text-align: center;
  color: #999;
  padding-top: 200rpx;
}