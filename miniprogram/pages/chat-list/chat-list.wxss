.container { min-height: 100vh; padding: 42rpx 24rpx; box-sizing: border-box; }.page-head { padding: 0 12rpx 26rpx; }.title { display: block; margin-top: 8rpx; font-size: 42rpx; font-weight: 700; letter-spacing: -2rpx; }.subtitle { display: block; margin-top: 7rpx; color: var(--text-secondary); font-size: 25rpx; }.conversation-list { border-radius: var(--radius-lg); overflow: hidden; background: var(--card-bg); box-shadow: var(--shadow); }.conv-item { display: flex; align-items: center; min-height: 126rpx; padding: 20rpx; border-bottom: 1rpx solid var(--border); transition: transform 150ms var(--ease-out), background-color 150ms ease; }.conv-item:last-child { border-bottom: 0; }.conv-avatar { width: 84rpx; height: 84rpx; margin-right: 18rpx; border-radius: 50%; background: var(--brand-soft); }.conv-info { display: flex; min-width: 0; flex: 1; flex-direction: column; }.conv-name { color: var(--text-main); font-size: 29rpx; font-weight: 700; }.conv-item-title { margin-top: 3rpx; color: var(--brand); font-size: 21rpx; }.conv-lastmsg { overflow: hidden; margin-top: 5rpx; color: var(--text-secondary); font-size: 24rpx; text-overflow: ellipsis; white-space: nowrap; }.unread-badge { display: flex; min-width: 38rpx; height: 38rpx; align-items: center; justify-content: center; margin-left: 12rpx; padding: 0 5rpx; border-radius: 20rpx; background: var(--coral); color: #fff; font-size: 21rpx; }.arrow { margin-left: 12rpx; color: #a4ada6; font-size: 40rpx; }.empty { display: flex; flex-direction: column; align-items: center; margin-top: 180rpx; color: var(--text-secondary); text-align: center; font-size: 25rpx; }.empty-mark { display: flex; width: 100rpx; height: 100rpx; align-items: center; justify-content: center; margin-bottom: 22rpx; border-radius: 32rpx; background: var(--accent-soft); color: var(--coral); font-size: 48rpx; }.empty-title { margin-bottom: 8rpx; color: var(--text-main); font-size: 33rpx; font-weight: 700; }
