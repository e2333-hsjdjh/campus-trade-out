<view class="container">
  <view class="page-intro"><text class="eyebrow">REFRESH THE STORY</text><text class="title">编辑商品</text><text class="subtitle">更新价格、描述和照片，让信息保持准确。</text></view>
  <view wx:if="{{loading}}" class="loading-state">正在加载商品信息...</view>
  <view wx:else class="form-card">
    <text class="field-label">商品照片 <text>保留 1—9 张，第一张为封面</text></text>
    <view class="image-list"><block wx:for="{{images}}" wx:key="*this"><view class="image-item"><image src="{{item}}" mode="aspectFill"/><view class="del-btn pressable" bindtap="deleteImage" data-index="{{index}}">×</view></view></block><view class="add-btn pressable" bindtap="chooseImage" wx:if="{{images.length < 9}}"><text class="add-plus">+</text><text>添加</text></view></view>
    <view class="form-divider"></view>
    <text class="field-label">商品信息</text>
    <input class="form-input" placeholder="给它起个清楚的标题" bindinput="onInput" data-field="title" value="{{title}}" />
    <view class="select-row"><view class="picker-wrap"><text class="picker-label">分类</text><picker mode="selector" range="{{categories}}" bindchange="onCategoryChange"><text class="{{category ? 'selected' : 'placeholder'}}">{{category || '选择分类'}}  ›</text></picker></view><view class="picker-wrap"><text class="picker-label">成色</text><picker mode="selector" range="{{conditions}}" bindchange="onConditionChange"><text class="{{condition ? 'selected' : 'placeholder'}}">{{condition || '选择成色'}}  ›</text></picker></view></view>
    <view class="price-row"><text>¥</text><input type="digit" placeholder="0.00" bindinput="onInput" data-field="price" value="{{price}}" /></view>
    <textarea class="description" placeholder="说说来源、使用情况和交易偏好吧…" bindinput="onInput" data-field="description" value="{{description}}" maxlength="300" />
  </view>
  <button wx:if="{{!loading}}" class="btn-primary submit-btn" bindtap="saveItem" loading="{{submitting}}" disabled="{{!canSubmit}}">保存修改</button>
</view>
