<view class="category-page">
  <view class="category-hero">
    <text class="hero-kicker">{{schoolName}} · 同校闲置</text>
    <text class="hero-title">{{categoryLabel}}</text>
    <text class="hero-copy">共找到 {{total}} 件正在流转的好物</text>
  </view>

  <view class="filter-panel">
    <scroll-view scroll-x class="condition-scroll" show-scrollbar="{{false}}">
      <view class="condition-row">
        <view class="condition-chip {{selectedCondition === item.value ? 'active' : ''}}" wx:for="{{conditions}}" wx:key="value" bindtap="selectCondition" data-value="{{item.value}}">{{item.label}}</view>
      </view>
    </scroll-view>
    <view class="sort-button pressable" bindtap="chooseSort">{{sortLabel}}⌄</view>
  </view>

  <view wx:if="{{items.length > 0}}" class="goods-grid">
    <view class="goods-card pressable" wx:for="{{items}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <image class="goods-image" src="{{item.images[0] || ''}}" mode="aspectFill"/>
      <view class="goods-body"><text class="goods-title">{{item.title}}</text><view class="tags"><text>{{item.condition}}</text><text>{{item.category}}</text></view><view class="goods-bottom"><text class="price">¥{{item.price}}</text><text>{{item.createTimeFormat}}</text></view></view>
    </view>
  </view>

  <view wx:if="{{!loading && items.length === 0}}" class="empty-state"><view>空</view><text>这个分类还没有在售商品</text><button bindtap="goPublish">发布一件</button></view>
  <view wx:if="{{loading}}" class="load-state">正在加载...</view>
  <view wx:if="{{!loading && !hasMore && items.length > 0}}" class="load-state">没有更多了</view>
</view>
