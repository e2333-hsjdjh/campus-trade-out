.category-page { box-sizing: border-box; min-height: 100vh; padding-bottom: 48rpx; background: #f5f6f8; }.category-hero { padding: 38rpx 28rpx 34rpx; background: linear-gradient(135deg,#244b80,#3973bf); color: #fff; }.hero-kicker, .hero-title, .hero-copy { display: block; }.hero-kicker { color: rgba(255,255,255,.7); font-size: 21rpx; }.hero-title { margin-top: 8rpx; font-size: 45rpx; font-weight: 850; letter-spacing: -1rpx; }.hero-copy { margin-top: 7rpx; color: rgba(255,255,255,.72); font-size: 23rpx; }.filter-panel { position: sticky; z-index: 4; top: 0; display: flex; align-items: center; padding: 18rpx 18rpx; border-bottom: 1rpx solid #e8ebef; background: rgba(255,255,255,.97); }.condition-scroll { min-width: 0; flex: 1; white-space: nowrap; }.condition-row { display: inline-flex; padding-right: 12rpx; }.condition-chip { margin-right: 10rpx; padding: 11rpx 18rpx; border-radius: 999rpx; background: #f1f3f6; color: #687280; font-size: 22rpx; }.condition-chip.active { background: var(--brand); color: #fff; font-weight: 700; }.sort-button { flex: 0 0 auto; padding: 12rpx 8rpx 12rpx 18rpx; border-left: 1rpx solid #e2e5ea; color: #485263; font-size: 22rpx; font-weight: 650; }.goods-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 14rpx; padding: 18rpx; }.goods-card { overflow: hidden; border-radius: 20rpx; background: #fff; box-shadow: 0 6rpx 18rpx rgba(31,35,41,.05); }.goods-image { width: 100%; height: 300rpx; background: #e8ebef; }.goods-body { padding: 15rpx; }.goods-title { display: -webkit-box; overflow: hidden; min-height: 74rpx; font-size: 26rpx; font-weight: 700; line-height: 1.4; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }.tags { display: flex; margin-top: 10rpx; }.tags text { margin-right: 7rpx; padding: 4rpx 8rpx; border-radius: 7rpx; background: #eff3f9; color: #65738a; font-size: 17rpx; }.goods-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 13rpx; color: #a0a7b2; font-size: 18rpx; }.goods-bottom .price { color: #ef5b40; font-size: 31rpx; font-weight: 850; }.empty-state { display: flex; flex-direction: column; align-items: center; padding: 130rpx 30rpx; color: #8d96a3; }.empty-state > view { display: flex; width: 100rpx; height: 100rpx; align-items: center; justify-content: center; border-radius: 32rpx; background: #eaf1ff; color: var(--brand); font-size: 30rpx; font-weight: 800; }.empty-state > text { margin-top: 20rpx; font-size: 24rpx; }.empty-state button { margin-top: 26rpx; border-radius: 999rpx; background: var(--brand); color: #fff; font-size: 23rpx; }.load-state { padding: 32rpx; color: #99a1ad; text-align: center; font-size: 22rpx; }
