.container { min-height: 100vh; padding: 42rpx 24rpx; box-sizing: border-box; }.search-head { padding: 0 12rpx 24rpx; }.title { display: block; margin-top: 8rpx; font-size: 42rpx; font-weight: 700; letter-spacing: -2rpx; }.search-bar { display: flex; align-items: center; height: 88rpx; padding-left: 24rpx; border: 1rpx solid var(--border); border-radius: 22rpx; background: var(--card-bg); box-shadow: 0 8rpx 22rpx rgba(39,57,48,0.05); }.search-glyph { margin-right: 14rpx; color: var(--text-secondary); font-size: 42rpx; line-height: 1; }.search-bar input { flex: 1; min-width: 0; font-size: 27rpx; }.search-action { margin: 8rpx; padding: 14rpx 20rpx; border-radius: 16rpx; background: var(--brand); color: #fff; font-size: 24rpx; font-weight: 600; transition: transform 150ms var(--ease-out); }.result-list { height: calc(100vh - 270rpx); margin-top: 26rpx; }.result-caption { margin: 0 0 14rpx 4rpx; color: var(--text-secondary); font-size: 23rpx; }.item-card { display: flex; min-height: 160rpx; margin-bottom: 16rpx; padding: 12rpx; border-radius: 22rpx; background: var(--card-bg); box-shadow: 0 8rpx 24rpx rgba(39,57,48,0.05); transition: transform 150ms var(--ease-out); }.item-img { width: 136rpx; height: 136rpx; margin-right: 20rpx; border-radius: 16rpx; background: #e9e8e2; }.item-info { display: flex; flex: 1; flex-direction: column; justify-content: space-between; padding: 4rpx 0; }.item-tag { align-self: flex-start; padding: 3rpx 10rpx; border-radius: 999rpx; background: var(--brand-soft); color: var(--brand); font-size: 20rpx; font-weight: 700; }.item-title { font-size: 29rpx; font-weight: 650; }.item-price { color: var(--coral); font-size: 34rpx; font-weight: 700; }.empty { display: flex; flex-direction: column; align-items: center; margin-top: 190rpx; color: var(--text-secondary); text-align: center; font-size: 25rpx; }.empty-mark { display: flex; width: 96rpx; height: 96rpx; align-items: center; justify-content: center; margin-bottom: 20rpx; border-radius: 32rpx; background: var(--accent-soft); color: var(--coral); font-size: 50rpx; }.empty-title { margin-bottom: 8rpx; color: var(--text-main); font-size: 32rpx; font-weight: 700; }.suggestion { margin: 42rpx 10rpx; color: var(--text-secondary); font-size: 24rpx; }.suggestion view { display: flex; margin-top: 16rpx; }.suggestion view text { margin-right: 14rpx; padding: 10rpx 18rpx; border-radius: 999rpx; background: var(--card-bg); color: var(--brand); font-size: 23rpx; }
