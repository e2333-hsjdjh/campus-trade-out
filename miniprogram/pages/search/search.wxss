/* pages/search/search.wxss */
.container {
  padding: 20rpx;
}
.search-bar {
  display: flex;
  margin-bottom: 30rpx;
}
.search-bar input {
  flex: 1;
  background: #f1f1f1;
  border-radius: 30rpx;
  padding: 10rpx 30rpx;
  margin-right: 20rpx;
}
.search-btn {
  background: #07c160;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
}
.item-card {
  background: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  display: flex;
  padding: 20rpx;
}
.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
}
.item-info {
  flex: 1;
}
.item-title {
  font-size: 30rpx;
  font-weight: bold;
}
.item-price {
  color: #e74c3c;
  font-size: 32rpx;
  margin-top: 10rpx;
}
.empty {
  text-align: center;
  margin-top: 100rpx;
  color: #999;
}