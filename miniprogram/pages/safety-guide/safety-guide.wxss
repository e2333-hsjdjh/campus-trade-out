.guide-page { box-sizing: border-box; min-height: 100vh; padding: 34rpx 24rpx 60rpx; background: #f5f6f8; }.guide-hero { display: flex; flex-direction: column; align-items: center; padding: 46rpx 30rpx 40rpx; text-align: center; }.shield { display: flex; width: 104rpx; height: 104rpx; align-items: center; justify-content: center; border-radius: 34rpx; background: linear-gradient(145deg,#28538d,#3976c5); color: #fff; font-size: 34rpx; font-weight: 850; box-shadow: 0 14rpx 30rpx rgba(37,99,235,.2); }.hero-title { margin-top: 24rpx; font-size: 39rpx; font-weight: 850; }.hero-copy { margin-top: 8rpx; color: #7e8794; font-size: 23rpx; }.guide-card, .warning-card { overflow: hidden; border-radius: 24rpx; background: #fff; box-shadow: 0 6rpx 20rpx rgba(31,35,41,.04); }.guide-row { display: flex; align-items: flex-start; padding: 25rpx 22rpx; border-bottom: 1rpx solid #edf0f3; }.guide-row:last-child { border-bottom: 0; }.step { display: flex; width: 54rpx; height: 54rpx; flex: 0 0 auto; align-items: center; justify-content: center; margin-right: 17rpx; border-radius: 18rpx; font-size: 22rpx; font-weight: 850; }.blue { background: #eaf1ff; color: #3975d4; }.green { background: #e7f7ed; color: #358c59; }.orange { background: #fff0df; color: #d77727; }.violet { background: #f0edff; color: #7060cf; }.guide-row > view:last-child { display: flex; flex-direction: column; }.guide-row > view:last-child text:first-child { font-size: 27rpx; font-weight: 750; }.guide-row > view:last-child text:last-child { margin-top: 5rpx; color: #7f8997; font-size: 22rpx; line-height: 1.55; }.warning-card { margin-top: 18rpx; padding: 24rpx; border: 1rpx solid #f5d7d1; background: #fff9f7; }.warning-card > text { display: block; margin-bottom: 13rpx; color: #bf513c; font-size: 27rpx; font-weight: 800; }.warning-card > view { display: flex; margin-top: 8rpx; color: #775f5a; font-size: 21rpx; line-height: 1.5; }.warning-card > view text:first-child { margin-right: 10rpx; color: #e6674d; }.primary-button, .secondary-button { display: flex; box-sizing: border-box; width: 100%; height: 86rpx; align-items: center; justify-content: center; margin-right: 0; margin-left: 0; padding: 0 28rpx; border-radius: 999rpx; font-size: 25rpx; font-weight: 600; line-height: 1.2; white-space: nowrap; transition: transform 150ms var(--ease-out), opacity 150ms ease; }.primary-button { margin-top: 28rpx; background: var(--brand); color: #fff; box-shadow: 0 10rpx 24rpx rgba(37,99,235,.16); }.secondary-button { height: 82rpx; margin-top: 14rpx; border: 1rpx solid #d9dde4; background: #fff; color: #394250; font-size: 24rpx; }.primary-button:active, .secondary-button:active { transform: scale(.98); opacity: .88; }.report-link { display: block; margin-top: 25rpx; color: #6f7a8a; text-align: center; font-size: 22rpx; }
