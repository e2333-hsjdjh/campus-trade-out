.container {
  padding-bottom: 120rpx;
}
.swiper {
  width: 100%;
  height: 600rpx;
}
.swiper-img {
  width: 100%;
  height: 100%;
}
.info {
  padding: 30rpx;
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
}
.price {
  font-size: 48rpx;
  color: var(--danger);
  font-weight: bold;
  display: block;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin: 20rpx 0;
  display: block;
}
.meta {
  display: flex;
  justify-content: space-between;
  color: var(--text-secondary);
  font-size: 26rpx;
}
.seller {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
}
.seller-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 20rpx;
}
.seller-name {
  font-size: 30rpx;
}
.desc {
  background: #fff;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 12rpx;
}
.desc-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}
.desc-content {
  color: #555;
  font-size: 28rpx;
  line-height: 1.6;
}
.footer {
  position: fixed;
  bottom: 0;
  width: 100%;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
}
.want-btn {
  flex: 1;
}