.detail-page { min-height: 100vh; padding-bottom: calc(142rpx + env(safe-area-inset-bottom)); background: #f5f6f8; }.gallery { position: relative; width: 100%; height: 720rpx; background: #e5e8ed; }.gallery-swiper, .gallery-image { width: 100%; height: 100%; }.gallery-count, .status-float { position: absolute; z-index: 2; border-radius: 999rpx; color: #fff; font-size: 20rpx; }.gallery-count { right: 24rpx; bottom: 22rpx; padding: 8rpx 14rpx; background: rgba(19,27,40,.66); }.status-float { top: 24rpx; left: 24rpx; padding: 9rpx 16rpx; font-weight: 750; }.status-float.selling { background: rgba(37,99,235,.92); }.status-float.inactive { background: rgba(70,76,87,.82); }
.content-stack { padding: 18rpx 18rpx 40rpx; }.summary-card, .info-card, .seller-card, .promise-card, .safety-link { border-radius: 22rpx; background: #fff; box-shadow: 0 6rpx 18rpx rgba(31,35,41,.04); }.summary-card { padding: 25rpx 22rpx 26rpx; }.price-row, .section-heading, .seller-card, .safety-link { display: flex; align-items: center; justify-content: space-between; }.price { color: #ef5d42; font-size: 54rpx; font-weight: 850; letter-spacing: -2rpx; }.price > text { margin-right: 3rpx; font-size: 25rpx; }.publish-time { color: #9aa2ad; font-size: 20rpx; }.item-title { display: block; margin-top: 10rpx; color: #202631; font-size: 38rpx; font-weight: 800; line-height: 1.35; }.tag-row { display: flex; margin-top: 18rpx; }.tag-row text { margin-right: 9rpx; padding: 6rpx 11rpx; border-radius: 8rpx; background: #eff4fb; color: #5d6e87; font-size: 19rpx; }
.info-card { margin-top: 16rpx; padding: 24rpx 22rpx; }.section-heading text:first-child { font-size: 29rpx; font-weight: 800; }.section-heading text:last-child { color: #9ca4af; font-size: 19rpx; }.spec-grid { display: grid; grid-template-columns: repeat(3,1fr); margin-top: 22rpx; padding: 20rpx 0; border-radius: 16rpx; background: #f7f8fa; }.spec-grid view { display: flex; flex-direction: column; align-items: center; border-right: 1rpx solid #e5e8ed; }.spec-grid view:last-child { border-right: 0; }.spec-grid text:first-child { color: #969faa; font-size: 19rpx; }.spec-grid text:last-child { margin-top: 4rpx; color: #333b48; font-size: 23rpx; font-weight: 700; }.description { margin-top: 24rpx; }.description > text:first-child { display: block; color: #343c49; font-size: 24rpx; font-weight: 750; }.description > text:last-child { display: block; margin-top: 11rpx; color: #626d7c; font-size: 26rpx; line-height: 1.72; white-space: pre-wrap; }
.seller-card { margin-top: 16rpx; padding: 22rpx; }.seller-card.contactable { transition: transform 150ms var(--ease-out); }.seller-avatar { width: 86rpx; height: 86rpx; flex: 0 0 auto; margin-right: 16rpx; border: 3rpx solid #e7edf7; border-radius: 50%; background: #edf1f6; }.seller-copy { display: flex; min-width: 0; flex: 1; flex-direction: column; }.seller-copy > view { display: flex; align-items: center; }.seller-name { overflow: hidden; max-width: 260rpx; font-size: 28rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }.verified { margin-left: 8rpx; padding: 4rpx 8rpx; border-radius: 7rpx; background: #eaf1ff; color: var(--brand); font-size: 17rpx; font-weight: 700; }.seller-copy > text { margin-top: 4rpx; color: #9099a6; font-size: 20rpx; }.seller-badge { padding: 8rpx 12rpx; border-radius: 10rpx; background: #e9f7ee; color: #37885a; font-size: 19rpx; font-weight: 750; }
.comment-card { margin-top: 16rpx; padding: 24rpx 22rpx; border-radius: 22rpx; background: #fff; box-shadow: 0 6rpx 18rpx rgba(31,35,41,.04); }.comment-heading, .comment-heading > view, .comment-submit-row, .comment-meta, .comment-meta > view { display: flex; align-items: center; }.comment-heading { justify-content: space-between; }.comment-heading > view > text:first-child { color: #29313c; font-size: 29rpx; font-weight: 800; }.comment-heading > view > text:last-child { min-width: 30rpx; margin-left: 9rpx; padding: 2rpx 8rpx; border-radius: 999rpx; background: #eef3fb; color: #65748b; font-size: 18rpx; text-align: center; }.comment-heading > text { color: #9aa2ad; font-size: 19rpx; }.comment-composer { margin-top: 20rpx; padding: 17rpx; border: 1rpx solid #dce5f3; border-radius: 18rpx; background: #f7f9fc; }.comment-input { box-sizing: border-box; width: 100%; min-height: 78rpx; max-height: 190rpx; color: #2e3540; font-size: 24rpx; line-height: 1.55; }.comment-submit-row { justify-content: space-between; margin-top: 12rpx; }.comment-submit-row > text { color: #a0a8b4; font-size: 18rpx; }.comment-submit { display: flex; width: 146rpx; height: 58rpx; align-items: center; justify-content: center; margin: 0; padding: 0; border-radius: 999rpx; background: var(--brand); color: #fff; font-size: 21rpx; font-weight: 700; line-height: 1.2; }.comment-submit[disabled] { background: #c7d1e0; color: rgba(255,255,255,.9); }.comment-owner-tip { margin-top: 18rpx; padding: 17rpx 19rpx; border-radius: 15rpx; background: #f6f7f9; color: #87909e; font-size: 21rpx; }.comment-item { display: flex; align-items: flex-start; padding: 22rpx 0; border-bottom: 1rpx solid #edf0f3; }.comment-item:last-of-type { border-bottom: 0; }.comment-item > image { width: 64rpx; height: 64rpx; flex: 0 0 auto; margin-right: 14rpx; border-radius: 50%; background: #edf1f6; }.comment-body { min-width: 0; flex: 1; }.comment-meta { justify-content: space-between; }.comment-meta > view > text:first-child { overflow: hidden; max-width: 250rpx; color: #414a58; font-size: 22rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }.comment-meta > view > text:last-child { margin-left: 7rpx; padding: 2rpx 6rpx; border-radius: 6rpx; background: #eaf1ff; color: var(--brand); font-size: 15rpx; }.comment-meta > text { margin-left: 10rpx; color: #a0a7b2; font-size: 17rpx; }.comment-content { display: block; margin-top: 7rpx; color: #4f5968; font-size: 24rpx; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }.comment-empty { display: flex; flex-direction: column; align-items: center; padding: 42rpx 10rpx 26rpx; text-align: center; }.comment-empty text:first-child { color: #687383; font-size: 24rpx; font-weight: 700; }.comment-empty text:last-child { margin-top: 5rpx; color: #a0a7b2; font-size: 20rpx; }.comment-limit-note { display: block; padding-top: 18rpx; color: #9ca5b1; text-align: center; font-size: 18rpx; }
.promise-card { display: flex; align-items: center; margin-top: 16rpx; padding: 20rpx 22rpx; background: linear-gradient(135deg,#f4f8ff,#edf4ff); }.promise-icon { display: flex; width: 58rpx; height: 58rpx; flex: 0 0 auto; align-items: center; justify-content: center; margin-right: 15rpx; border-radius: 19rpx; background: var(--brand); color: #fff; font-size: 21rpx; font-weight: 850; }.promise-card > view:last-child { display: flex; flex-direction: column; }.promise-card > view:last-child text:first-child { color: #314560; font-size: 24rpx; font-weight: 750; }.promise-card > view:last-child text:last-child { margin-top: 3rpx; color: #7a899d; font-size: 19rpx; }
.safety-link { margin-top: 16rpx; padding: 22rpx; transition: transform 150ms var(--ease-out); }.safety-link > view { display: flex; flex-direction: column; }.safety-link > view text:first-child { font-size: 26rpx; font-weight: 750; }.safety-link > view text:last-child { margin-top: 4rpx; color: #9099a6; font-size: 20rpx; }.safety-link > text { color: var(--brand); font-size: 20rpx; font-weight: 650; }.detail-note { display: block; padding: 25rpx 22rpx 0; color: #a0a7b2; text-align: center; font-size: 19rpx; line-height: 1.55; }
.bottom-bar { position: fixed; z-index: 10; right: 0; bottom: 0; left: 0; display: flex; align-items: center; box-sizing: border-box; min-height: 116rpx; padding: 12rpx 18rpx calc(12rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #e6e9ed; background: rgba(255,255,255,.98); box-shadow: 0 -8rpx 24rpx rgba(31,35,41,.05); }.bar-tool { display: flex; box-sizing: border-box; width: 86rpx; height: 88rpx; flex: 0 0 auto; flex-direction: column; align-items: center; justify-content: center; margin: 0 4rpx 0 0; padding: 0; border-radius: 16rpx; background: transparent; color: #4d5969; font-size: inherit; font-weight: 500; line-height: 1; }.bar-tool .tool-icon { position: relative; display: flex; width: 44rpx; height: 40rpx; flex: 0 0 auto; align-items: center; justify-content: center; background: transparent; color: currentColor; }.bar-tool > text { display: block; margin-top: 7rpx; color: currentColor; font-size: 21rpx; font-weight: 550; line-height: 1; white-space: nowrap; }.share-tool { font-weight: 500; }.share-tool::after { border: 0; }.home-roof { position: absolute; top: 6rpx; left: 10rpx; box-sizing: border-box; width: 24rpx; height: 24rpx; border-top: 4rpx solid currentColor; border-left: 4rpx solid currentColor; border-radius: 3rpx; background: transparent; transform: rotate(45deg); }.home-body { position: absolute; right: 9rpx; bottom: 3rpx; left: 9rpx; box-sizing: border-box; height: 22rpx; border: 4rpx solid currentColor; border-top: 0; border-radius: 0 0 5rpx 5rpx; background: #fff; }.share-arrow { position: absolute; top: 4rpx; left: 18rpx; width: 18rpx; height: 18rpx; border-top: 4rpx solid currentColor; border-right: 4rpx solid currentColor; background: transparent; }.share-arrow::after { position: absolute; top: 5rpx; right: -2rpx; width: 28rpx; height: 4rpx; border-radius: 999rpx; background: currentColor; content: ''; transform: rotate(-45deg); transform-origin: right center; }.share-tray { position: absolute; right: 7rpx; bottom: 2rpx; left: 7rpx; box-sizing: border-box; height: 24rpx; border: 4rpx solid currentColor; border-top: 0; border-radius: 0 0 6rpx 6rpx; background: transparent; }.favorite-icon > text { display: block; margin: -2rpx 0 0; color: currentColor; font-family: Arial, sans-serif; font-size: 43rpx; font-weight: 400; line-height: 1; }.favorite-tool.favorited { color: #e16631; }.favorite-tool.favorited .favorite-icon { color: #e16631; }.favorite-tool[disabled] { opacity: .62; }.owner-controls, .buyer-controls { display: flex; min-width: 0; flex: 1; align-items: center; gap: 8rpx; margin-left: 8rpx; }.status-action, .owner-edit-action { display: flex; box-sizing: border-box; height: 76rpx; align-items: center; justify-content: center; margin: 0; padding: 0 12rpx; border-radius: 999rpx; font-size: 21rpx; font-weight: 650; line-height: 1.2; }.status-action { min-width: 102rpx; border: 1rpx solid #dce1e8; background: #fff; color: #4f5b6b; }.sold-action { border-color: #cfe2d7; background: #f1f8f4; color: #347451; }.delist-action { border-color: #f0d8d2; background: #fff7f5; color: #c25d48; }.relist-action { min-width: 146rpx; border-color: #cddcf5; background: #f2f6fd; color: #3569b7; }.owner-edit-action { min-width: 112rpx; flex: 1; background: #24354f; color: #fff; }.status-action[disabled], .owner-edit-action[disabled] { opacity: .58; }.message-action { display: flex; box-sizing: border-box; width: 112rpx; height: 86rpx; flex: 0 0 auto; align-items: center; justify-content: center; margin: 0; padding: 0 12rpx; border: 1rpx solid #cbd9f0; border-radius: 999rpx; background: #f4f7fc; color: #315f9e; font-size: 22rpx; font-weight: 650; line-height: 1.2; }.buyer-controls .primary-action { margin: 0; }.primary-action { display: flex; height: 86rpx; flex: 1; align-items: center; justify-content: center; margin: 0 0 0 8rpx; padding: 0 14rpx; border-radius: 999rpx; background: var(--brand); color: #fff; font-size: 25rpx; font-weight: 750; line-height: 86rpx; transition: transform 150ms var(--ease-out), opacity 150ms ease; }.primary-action:active { transform: scale(.97); }.primary-action[disabled] { background: #9db1d2; color: rgba(255,255,255,.85); }.message-action[disabled] { opacity: .58; }.disabled-action { background: #c5cbd4; }
.state-page { display: flex; box-sizing: border-box; min-height: 100vh; flex-direction: column; align-items: center; justify-content: center; padding: 70rpx 46rpx; background: #f5f6f8; text-align: center; }.state-symbol { display: flex; width: 104rpx; height: 104rpx; align-items: center; justify-content: center; border-radius: 34rpx; background: #fff0ed; color: #d45b45; font-size: 40rpx; font-weight: 850; }.state-title { margin-top: 24rpx; font-size: 32rpx; font-weight: 800; }.state-copy { margin-top: 10rpx; color: #7d8795; font-size: 23rpx; line-height: 1.6; }.state-page button { width: 280rpx; margin-top: 28rpx; border-radius: 999rpx; background: var(--brand); color: #fff; font-size: 24rpx; }.back-home { margin-top: 22rpx; color: #6d7888; font-size: 22rpx; }.loading-page { justify-content: flex-start; padding-top: 24rpx; }.skeleton-image { width: 100%; height: 620rpx; border-radius: 20rpx; background: #e6e9ee; }.skeleton-line { width: 62%; height: 28rpx; align-self: flex-start; margin-top: 20rpx; border-radius: 999rpx; background: #e6e9ee; }.skeleton-line.wide { width: 88%; height: 48rpx; }.loading-page > text { margin-top: 36rpx; color: #929ba8; font-size: 22rpx; }
.bar-tool .tool-icon-image { display: block; width: 44rpx; height: 44rpx; flex: 0 0 auto; background: transparent; }
.comment-meta > view > .seller-comment-badge { background: #fff0e7; color: #cf6535; }
.tag-row .demo-tag { background: #fff0e7; color: #cf6535; font-weight: 700; }

/* 底栏工具与业务操作分组，避免原生 button 的自动外边距拉伸整行。 */
.bottom-bar { min-height: 108rpx; padding: 10rpx 20rpx calc(10rpx + env(safe-area-inset-bottom)); }
.bottom-utilities { display: flex; flex: 0 0 auto; align-items: center; gap: 2rpx; }
.bottom-bar .bar-tool { width: 72rpx; min-width: 72rpx; max-width: 72rpx; height: 76rpx; flex: 0 0 72rpx; margin: 0; border-radius: 14rpx; color: #647083; transition: transform 140ms var(--ease-out), opacity 140ms ease; }
.bottom-bar .bar-tool > text { margin-top: 5rpx; font-size: 18rpx; font-weight: 600; }
.bottom-bar .bar-tool .tool-icon-image { width: 34rpx; height: 34rpx; }
.favorite-tool.favorited { color: #df6335; }
.favorite-tool.is-disabled { opacity: .55; }
.owner-controls, .buyer-controls { gap: 8rpx; margin-left: 10rpx; }
.status-action, .owner-edit-action { height: 72rpx; padding: 0 10rpx; font-size: 20rpx; }
.status-action { min-width: 94rpx; }
.relist-action { min-width: 136rpx; }
.owner-edit-action { min-width: 106rpx; }
.message-action { width: 102rpx; height: 76rpx; padding: 0 10rpx; font-size: 20rpx; }
.primary-action { height: 76rpx; margin-left: 10rpx; padding: 0 12rpx; font-size: 23rpx; line-height: 76rpx; }

/* 窄屏最终约束：工具只保留图标，卖家操作平均使用剩余空间。 */
.detail-page { padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }
.bottom-bar { overflow: hidden; min-height: 92rpx; gap: 0; padding: 10rpx 18rpx calc(10rpx + env(safe-area-inset-bottom)); }
.bottom-utilities { gap: 8rpx; margin-right: 12rpx; }
.bottom-bar .bar-tool,
.bottom-bar button.bar-tool { display: flex !important; box-sizing: border-box !important; width: 58rpx !important; min-width: 58rpx !important; max-width: 58rpx !important; height: 58rpx !important; flex: 0 0 58rpx !important; margin: 0 !important; padding: 0 !important; border-radius: 18rpx; background: #f4f6f9; }
.bottom-bar .bar-tool > text { display: none; }
.bottom-bar .bar-tool .tool-icon-image { width: 30rpx; height: 30rpx; }
.owner-controls { min-width: 0; flex: 1; gap: 6rpx; margin-left: 0; }
.owner-controls .status-action,
.owner-controls .owner-edit-action { width: auto; min-width: 0; height: 68rpx; flex: 1 1 0; padding: 0 6rpx; font-size: 18rpx; white-space: nowrap; }
.buyer-controls { margin-left: 0; }
.message-action { width: 96rpx; height: 70rpx; font-size: 19rpx; }
.buyer-controls .primary-action,
.bottom-bar > .disabled-action { height: 70rpx; margin-left: 0; font-size: 22rpx; line-height: 70rpx; }
