.container { min-height: 100vh; padding-bottom: 132rpx; }.swiper { width: 100%; height: 680rpx; background: #dedfd8; }.swiper-img { width: 100%; height: 100%; }.content { padding: 26rpx 24rpx; }.top-line { display: flex; align-items: center; justify-content: space-between; }.condition-pill { padding: 7rpx 14rpx; border-radius: 999rpx; background: var(--accent-soft); color: #9a6220; font-size: 22rpx; font-weight: 700; }.time { color: #9aa39c; font-size: 22rpx; }.price { display: block; margin-top: 18rpx; color: var(--coral); font-size: 54rpx; font-weight: 750; letter-spacing: -2rpx; }.title { display: block; margin-top: 5rpx; font-size: 38rpx; font-weight: 700; line-height: 1.3; }.meta { display: block; margin-top: 10rpx; color: var(--text-secondary); font-size: 25rpx; }.seller, .desc { margin-top: 24rpx; padding: 24rpx; border-radius: var(--radius-lg); background: var(--card-bg); box-shadow: 0 8rpx 26rpx rgba(39,57,48,0.05); }.seller { display: flex; align-items: center; }.seller-avatar { width: 76rpx; height: 76rpx; margin-right: 16rpx; border-radius: 50%; background: var(--brand-soft); }.seller-label { display: block; color: var(--text-secondary); font-size: 21rpx; }.seller-name { display: block; margin-top: 2rpx; font-size: 29rpx; font-weight: 650; }.seller-arrow { margin-left: auto; color: var(--text-secondary); font-size: 38rpx; }.desc-title { display: block; font-size: 29rpx; font-weight: 700; }.desc-content { display: block; margin-top: 14rpx; color: #536059; font-size: 27rpx; line-height: 1.72; }.footer { position: fixed; z-index: 2; right: 0; bottom: 0; left: 0; box-sizing: border-box; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(255,253,249,0.96); box-shadow: 0 -8rpx 24rpx rgba(39,57,48,0.06); }.want-btn { width: 100%; height: 90rpx; border-radius: 999rpx; background: var(--brand); color: #fff; font-size: 31rpx; font-weight: 650; line-height: 90rpx; transition: transform 150ms var(--ease-out); }.want-btn:active { transform: scale(0.97); }.footer-tip { display: block; color: var(--text-secondary); text-align: center; font-size: 27rpx; line-height: 90rpx; }.loading { padding-top: 260rpx; color: var(--text-secondary); text-align: center; }
