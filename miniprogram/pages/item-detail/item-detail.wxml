<view class="detail-page" wx:if="{{item}}">
  <view class="gallery">
    <swiper class="gallery-swiper" circular="{{item.imageCount > 1}}" bindchange="onSwiperChange">
      <swiper-item wx:for="{{item.images}}" wx:key="*this">
        <image class="gallery-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-src="{{item}}"/>
      </swiper-item>
    </swiper>
    <view class="gallery-count" wx:if="{{item.imageCount > 0}}">{{imageIndex + 1}} / {{item.imageCount}}</view>
    <view class="status-float {{item.status === '在售' ? 'selling' : 'inactive'}}">{{item.status}}</view>
  </view>

  <view class="content-stack">
    <view class="summary-card">
      <view class="price-row"><text class="price"><text>¥</text>{{item.price}}</text><text class="publish-time">发布于 {{item.createTimeFormat}}</text></view>
      <text class="item-title">{{item.title}}</text>
      <view class="tag-row"><text>{{item.category}}</text><text>{{item.condition}}</text><text>同校面交</text></view>
    </view>

    <view class="info-card">
      <view class="section-heading"><text>商品信息</text><text>真实描述更好成交</text></view>
      <view class="spec-grid">
        <view><text>分类</text><text>{{item.category}}</text></view>
        <view><text>成色</text><text>{{item.condition}}</text></view>
        <view><text>交易方式</text><text>校内面交</text></view>
      </view>
      <view class="description"><text>详细描述</text><text user-select="{{true}}">{{item.description || '卖家暂未补充更多描述，可以点击下方按钮进一步沟通。'}}</text></view>
    </view>

    <view class="seller-card {{canContact ? 'pressable contactable' : ''}}" bindtap="leaveMessage">
      <image class="seller-avatar" src="{{seller.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
      <view class="seller-copy"><view><text class="seller-name">{{seller.nickName || '校园同学'}}</text><text wx:if="{{seller.verified}}" class="verified">已认证</text></view><text>{{schoolName || '本校'}}同学 · 仅展示公开资料</text></view>
      <view class="seller-badge">{{canContact ? '去聊天 ›' : '校友'}}</view>
    </view>

    <view class="comment-card">
      <view class="comment-heading"><view><text>同学评论</text><text>{{commentCount}}</text></view><text>公开留言</text></view>
      <view wx:if="{{canContact}}" class="comment-composer">
        <textarea class="comment-input" value="{{commentText}}" maxlength="200" auto-height placeholder="想了解商品细节？在这里问问卖家和同学" bindinput="onCommentInput"></textarea>
        <view class="comment-submit-row"><text>{{commentText.length}} / 200</text><button class="comment-submit" loading="{{commentSubmitting}}" disabled="{{!canSubmitComment || commentSubmitting}}" bindtap="submitComment">发布评论</button></view>
      </view>
      <view wx:elif="{{isOwner}}" class="comment-owner-tip">这里会显示买家对商品的公开评论</view>
      <view wx:for="{{comments}}" wx:key="_id" class="comment-item">
        <image src="{{item.author.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="comment-body"><view class="comment-meta"><view><text>{{item.author.nickName || '校园同学'}}</text><text wx:if="{{item.author.verified}}">已认证</text></view><text>{{item.createTimeFormat}}</text></view><text class="comment-content" user-select="{{true}}">{{item.content}}</text></view>
      </view>
      <view wx:if="{{comments.length === 0}}" class="comment-empty"><text>还没有评论</text><text>{{canContact ? '你可以成为第一个提问的同学' : '买家的问题会显示在这里'}}</text></view>
      <text wx:if="{{commentCount > comments.length}}" class="comment-limit-note">当前展示最近 {{comments.length}} 条评论</text>
    </view>

    <view class="promise-card"><view class="promise-icon">验</view><view><text>当面验货，再确认交易</text><text>建议在教学楼、食堂等校内公共区域见面</text></view></view>

    <view class="safety-link pressable" bindtap="goSafetyGuide"><view><text>安全交易提醒</text><text>不提前支付押金，不点击陌生付款链接</text></view><text>查看指南 ›</text></view>
    <text class="detail-note">平台仅提供校园闲置信息与沟通服务，请根据实物情况自主判断。</text>
  </view>

  <view class="bottom-bar">
    <view class="bar-tool pressable" bindtap="goHome">
      <view class="tool-icon home-icon"><view class="home-roof"></view><view class="home-body"></view></view>
      <text>首页</text>
    </view>
    <button class="bar-tool share-tool pressable" open-type="share">
      <view class="tool-icon share-icon"><view class="share-arrow"></view><view class="share-tray"></view></view>
      <text>分享</text>
    </button>
    <button wx:if="{{!isOwner}}" class="bar-tool favorite-tool pressable {{isFavorited ? 'favorited' : ''}}" disabled="{{favoriteUpdating}}" bindtap="toggleFavorite">
      <view class="tool-icon favorite-icon"><text>{{isFavorited ? '♥' : '♡'}}</text></view>
      <text>{{isFavorited ? '已收藏' : '收藏'}}</text>
    </button>
    <view wx:if="{{isOwner}}" class="owner-controls">
      <button wx:if="{{item.status === '在售'}}" class="status-action sold-action" disabled="{{updatingStatus}}" bindtap="markSold">已售出</button>
      <button wx:if="{{item.status === '在售'}}" class="status-action delist-action" disabled="{{updatingStatus}}" bindtap="delistItem">下架</button>
      <button wx:else class="status-action relist-action" disabled="{{updatingStatus}}" bindtap="relistItem">重新上架</button>
      <button class="owner-edit-action" disabled="{{updatingStatus}}" bindtap="editItem">编辑</button>
    </view>
    <view wx:elif="{{canContact}}" class="buyer-controls">
      <button class="message-action" disabled="{{contacting}}" bindtap="leaveMessage">留言</button>
      <button class="primary-action" disabled="{{contacting}}" bindtap="wantItem">我想要</button>
    </view>
    <view wx:else class="primary-action disabled-action">当前商品{{item.status}}</view>
  </view>
</view>

<view wx:elif="{{loadError}}" class="state-page"><view class="state-symbol">!</view><text class="state-title">商品暂时无法展示</text><text class="state-copy">商品可能已删除、已下架，或当前账号无权查看。</text><button bindtap="retryLoad">重新加载</button><text class="back-home pressable" bindtap="goHome">返回首页</text></view>
<view wx:else class="state-page loading-page"><view class="skeleton-image"></view><view class="skeleton-line wide"></view><view class="skeleton-line"></view><text>正在加载商品信息...</text></view>
