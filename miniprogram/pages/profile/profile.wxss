.container { min-height: 100vh; padding: 42rpx 24rpx; box-sizing: border-box; }.page-head { padding: 0 12rpx 26rpx; }.title { display: block; margin-top: 8rpx; font-size: 42rpx; font-weight: 700; letter-spacing: -2rpx; }.subtitle { display: block; margin-top: 7rpx; color: var(--text-secondary); font-size: 24rpx; }.avatar-card, .form-card { border-radius: var(--radius-lg); background: var(--card-bg); box-shadow: var(--shadow); }.avatar-card { display: flex; align-items: center; padding: 24rpx; transition: transform 150ms var(--ease-out); }.avatar { width: 100rpx; height: 100rpx; margin-right: 20rpx; border-radius: 50%; background: var(--brand-soft); }.avatar-title { display: block; font-size: 29rpx; font-weight: 700; }.avatar-tip { display: block; margin-top: 5rpx; color: var(--text-secondary); font-size: 23rpx; }.arrow { margin-left: auto; color: #a8b0aa; font-size: 40rpx; }.form-card { margin-top: 20rpx; padding: 0 24rpx; }.form-item { padding: 24rpx 0 18rpx; border-bottom: 1rpx solid var(--border); }.form-item:last-child { border-bottom: 0; }.label { display: block; margin-bottom: 8rpx; color: var(--text-secondary); font-size: 22rpx; }.form-item input { font-size: 29rpx; }.privacy-note { display: block; margin: 18rpx 10rpx; color: var(--text-secondary); font-size: 22rpx; line-height: 1.65; }.save-btn { width: 100%; height: 92rpx; margin-top: 30rpx; line-height: 92rpx; }
