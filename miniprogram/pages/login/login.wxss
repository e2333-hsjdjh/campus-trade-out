.login-page { box-sizing: border-box; min-height: 100vh; background: #fff; color: #20242c; }
.login-nav { display: flex; align-items: center; justify-content: space-between; padding: 18rpx 34rpx; }.close-button { display: flex; width: 64rpx; height: 64rpx; align-items: center; justify-content: center; color: #161a20; font-size: 64rpx; font-weight: 300; line-height: 1; }.nav-help { color: #727b89; font-size: 24rpx; }
.login-main { padding: 84rpx 42rpx 0; }.identity { display: flex; flex-direction: column; align-items: center; }.identity-mark { position: relative; display: flex; width: 116rpx; height: 116rpx; align-items: center; justify-content: center; border-radius: 34rpx; background: var(--brand); color: #fff; box-shadow: 0 18rpx 40rpx rgba(37,99,235,.24); }.identity-mark text { font-size: 54rpx; font-weight: 850; }.mark-dot { position: absolute; top: 18rpx; right: 18rpx; width: 13rpx; height: 13rpx; border: 4rpx solid #fff; border-radius: 50%; background: var(--accent); }.identity-title { margin-top: 24rpx; font-size: 48rpx; font-weight: 850; letter-spacing: 2rpx; }.identity-slogan { margin-top: 9rpx; color: #8b94a2; font-size: 24rpx; }
.school-context { display: flex; align-items: center; margin-top: 74rpx; padding: 22rpx; border: 1rpx solid #e7eaf0; border-radius: 22rpx; background: #fafbfc; }.school-pin { display: flex; width: 62rpx; height: 62rpx; align-items: center; justify-content: center; margin-right: 16rpx; border-radius: 18rpx; background: var(--brand-soft); color: var(--brand); font-size: 25rpx; font-weight: 800; }.school-context view:nth-child(2) { display: flex; min-width: 0; flex: 1; flex-direction: column; }.school-context view:nth-child(2) text:first-child { color: #99a1ad; font-size: 19rpx; }.school-context view:nth-child(2) text:last-child { margin-top: 2rpx; font-size: 27rpx; font-weight: 700; }.context-arrow { color: var(--brand); font-size: 22rpx; font-weight: 650; }
.login-actions { margin-top: 30rpx; }.phone-login, .nickname-entry, .nickname-submit { width: 100%; height: 92rpx; margin: 0; border-radius: 999rpx; font-size: 29rpx; font-weight: 700; line-height: 92rpx; transition: transform 150ms var(--ease-out), opacity 150ms ease; }.phone-login { background: var(--brand); color: #fff; box-shadow: 0 12rpx 28rpx rgba(37,99,235,.18); }.phone-login[disabled] { background: #b9c6dc; color: rgba(255,255,255,.85); }.nickname-entry { margin-top: 20rpx; border: 1rpx solid #d8dce3; background: #fff; color: #323944; }.phone-login:active, .nickname-entry:active, .nickname-submit:active { transform: scale(.97); }.nickname-panel { margin-top: 20rpx; padding: 18rpx; border: 1rpx solid #dfe3e9; border-radius: 22rpx; background: #fafbfc; }.nickname-panel input { box-sizing: border-box; height: 78rpx; padding: 0 20rpx; border-radius: 16rpx; background: #fff; font-size: 26rpx; }.nickname-submit { height: 78rpx; margin-top: 14rpx; border-radius: 16rpx; background: #202a3a; color: #fff; line-height: 78rpx; }
.agreement { display: flex; align-items: flex-start; margin-top: 28rpx; padding: 0 4rpx; }.check-box { display: flex; width: 30rpx; height: 30rpx; flex: 0 0 auto; align-items: center; justify-content: center; margin: 3rpx 13rpx 0 0; border: 2rpx solid #c8ced8; border-radius: 50%; color: #fff; font-size: 20rpx; }.check-box.checked { border-color: var(--brand); background: var(--brand); }.agreement > text { color: #7d8694; font-size: 21rpx; line-height: 1.65; }
.login-footer { position: fixed; right: 0; bottom: calc(42rpx + env(safe-area-inset-bottom)); left: 0; display: flex; align-items: center; justify-content: center; color: #8e96a2; font-size: 22rpx; }.login-footer view { width: 1rpx; height: 22rpx; margin: 0 24rpx; background: #d8dce2; }
