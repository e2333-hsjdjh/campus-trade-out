.container { min-height: 100vh; background: var(--bg); }
.topbar { display: flex; align-items: center; justify-content: space-between; padding: 34rpx 32rpx 30rpx; background: #fff; border-bottom: 1rpx solid var(--border); }
.brand { display: flex; align-items: center; color: var(--text-main); font-size: 31rpx; font-weight: 700; }.brand-dot { width: 18rpx; height: 18rpx; margin-right: 12rpx; border-radius: 6rpx; background: var(--brand); }.topbar-note { color: var(--text-secondary); font-size: 22rpx; }
.content { padding: 64rpx 32rpx 50rpx; }.intro { margin-bottom: 40rpx; }.title { display: block; color: var(--text-main); font-size: 46rpx; font-weight: 700; letter-spacing: -2rpx; }.subtitle { display: block; margin-top: 14rpx; color: var(--text-secondary); font-size: 27rpx; }
.school-card, .profile-card { box-sizing: border-box; padding: 28rpx 26rpx; border-radius: var(--radius-lg); background: var(--card-bg); box-shadow: var(--shadow); }.field-title { display: block; margin-bottom: 20rpx; color: var(--text-main); font-size: 29rpx; font-weight: 650; }.search-bar { box-sizing: border-box; height: 80rpx; padding: 0 20rpx; border: 1rpx solid var(--border); border-radius: 12rpx; background: #fafbfc; }.search-bar input { height: 80rpx; font-size: 27rpx; }
.school-list { height: 350rpx; margin-top: 12rpx; }.school-item { display: flex; align-items: center; justify-content: space-between; min-height: 88rpx; padding: 0 10rpx; border-bottom: 1rpx solid #f0f1f3; color: var(--text-main); font-size: 28rpx; transition: transform 150ms var(--ease-out), background-color 150ms ease; }.school-item.active { color: var(--brand); font-weight: 650; }.radio { display: flex; width: 30rpx; height: 30rpx; align-items: center; justify-content: center; border: 2rpx solid #c9cdd4; border-radius: 50%; }.active .radio { border-color: var(--brand); }.radio-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--brand); }.empty-tip { padding: 60rpx 0; color: var(--text-secondary); text-align: center; }
.next-button { width: 100%; height: 92rpx; margin-top: 32rpx; line-height: 92rpx; }.login-divider { display: flex; align-items: center; gap: 18rpx; margin: 28rpx 0 20rpx; color: #a5acb8; font-size: 22rpx; }.login-divider view { flex: 1; height: 1rpx; background: var(--border); }.nickname-login { width: 100%; height: 88rpx; border: 1rpx solid var(--brand); border-radius: 999rpx; background: #fff; color: var(--brand); font-size: 29rpx; font-weight: 600; line-height: 88rpx; }.bottom-note { display: block; margin-top: 24rpx; color: #a5acb8; text-align: center; font-size: 22rpx; }
.profile-card { display: flex; flex-direction: column; align-items: center; padding-top: 38rpx; }.avatar-wrap { position: relative; overflow: hidden; width: 144rpx; height: 144rpx; border-radius: 50%; background: var(--brand-soft); }.avatar { width: 100%; height: 100%; }.avatar-mask { position: absolute; right: 0; bottom: 0; left: 0; padding: 9rpx 0; background: rgba(0,0,0,0.45); color: #fff; text-align: center; font-size: 19rpx; }.avatar-tip { margin: 14rpx 0 36rpx; color: var(--text-secondary); font-size: 23rpx; }.input-group { box-sizing: border-box; width: 100%; padding: 0 2rpx 14rpx; border-bottom: 2rpx solid var(--brand); }.input-group text { display: block; margin-bottom: 10rpx; color: var(--text-secondary); font-size: 22rpx; }.input-group input { font-size: 30rpx; }
