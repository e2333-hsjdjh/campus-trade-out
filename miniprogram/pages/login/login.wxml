<view class="login-page">
  <view class="safe-top" style="height: {{statusBarHeight}}px"></view>
  <view class="login-nav"><view class="close-button pressable" bindtap="closeLogin">×</view><text class="nav-help pressable" bindtap="showLoginHelp">登录帮助</text></view>

  <view class="login-main">
    <view class="identity">
      <view class="identity-mark"><view class="mark-dot"></view><text>集</text></view>
      <text class="identity-title">校园闲置</text>
      <text class="identity-slogan">让好物，在同一所校园继续流转</text>
    </view>

    <view class="school-context pressable" bindtap="changeSchool"><view class="school-pin">校</view><view><text>当前校园</text><text>{{selectedSchoolName}}</text></view><text class="context-arrow">更换 ›</text></view>

    <view class="login-actions">
      <button class="phone-login" open-type="getPhoneNumber" bindgetphonenumber="loginWithPhoneNumber" disabled="{{!agreementChecked}}">微信手机号快捷登录</button>
      <button wx:if="{{!nicknameMode}}" class="nickname-entry" bindtap="showNicknameMode">使用昵称登录</button>
      <view wx:else class="nickname-panel">
        <input type="nickname" maxlength="20" value="{{nickName}}" bindinput="onNickNameInput" placeholder="输入你在校园圈使用的昵称"/>
        <button class="nickname-submit" bindtap="doNicknameLogin">进入校园圈</button>
      </view>
    </view>

    <view class="agreement pressable" bindtap="toggleAgreement">
      <view class="check-box {{agreementChecked ? 'checked' : ''}}"><text wx:if="{{agreementChecked}}">✓</text></view>
      <text>我已阅读并同意《校园闲置服务说明》和《隐私保护指引》，手机号仅用于账号验证，不会公开展示。</text>
    </view>
  </view>

  <view class="login-footer"><text class="pressable" bindtap="showLoginHelp">登录遇到问题</text><view></view><text class="pressable" bindtap="closeLogin">先逛逛首页</text></view>
</view>
