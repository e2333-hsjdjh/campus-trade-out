<view class="container">
  <view class="topbar"><view class="brand"><view class="brand-dot"></view><text>校园闲置</text></view><text class="topbar-note">同校交易 · 更安心</text></view>

  <view class="content">
    <block wx:if="{{step === 1}}">
      <view class="intro"><text class="title">进入你的校园圈</text><text class="subtitle">看看身边同学正在转让的好物</text></view>
      <view class="school-card">
        <text class="field-title">选择学校</text>
        <view class="search-bar"><input placeholder="搜索学校名称" bindinput="onSearchSchool" value="{{searchKey}}" /></view>
        <scroll-view scroll-y class="school-list">
          <view class="school-item pressable {{selectedSchoolId === item.id ? 'active' : ''}}" wx:for="{{filteredSchools}}" wx:key="id" bindtap="selectSchool" data-id="{{item.id}}">
            <text>{{item.name}}</text><view class="radio"><view wx:if="{{selectedSchoolId === item.id}}" class="radio-dot"></view></view>
          </view>
          <view wx:if="{{filteredSchools.length === 0}}" class="empty-tip">没有找到这所学校</view>
        </scroll-view>
      </view>
      <button class="btn-primary next-button" bindtap="nextStep" disabled="{{!selectedSchoolId}}">继续</button>
      <text class="bottom-note">仅展示你所在学校的闲置商品</text>
    </block>

    <block wx:if="{{step === 2}}">
      <view class="intro"><text class="title">完善个人信息</text><text class="subtitle">在 {{selectedSchoolName}} 和同学友好交易</text></view>
      <view class="profile-card">
        <view class="avatar-wrap pressable" bindtap="getUserProfile"><image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/><view class="avatar-mask">更换头像</view></view>
        <text class="avatar-tip">点击获取微信头像和昵称</text>
        <view class="input-group"><text>昵称</text><input placeholder="请输入昵称" value="{{nickName}}" bindinput="onNickNameInput" /></view>
      </view>
      <button class="btn-primary next-button" open-type="getPhoneNumber" bindgetphonenumber="loginWithPhoneNumber">微信手机号快捷登录</button>
      <view class="login-divider"><view></view><text>或使用昵称登录</text><view></view></view>
      <button class="nickname-login" bindtap="doLogin">使用昵称进入</button>
      <text class="bottom-note">你的联系方式仅会在主动发送后展示给对方</text>
    </block>
  </view>
</view>
