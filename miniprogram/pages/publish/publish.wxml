<!--pages/publish/publish.wxml-->
<text>pages/publish/publish.wxml</text>
<view class="container">
  <view class="title">发布二手商品</view>

  <!-- 图片上传区域 -->
  <view class="image-section">
    <view class="image-list">
      <block wx:for="{{images}}" wx:key="*this">
        <view class="image-item">
          <image src="{{item}}" mode="aspectFill" />
          <view class="del-btn" bindtap="deleteImage" data-index="{{index}}">×</view>
        </view>
      </block>
      <view class="add-btn" bindtap="chooseImage" wx:if="{{images.length < 9}}">
        <text>+</text>
        <text>添加图片</text>
      </view>
    </view>
    <text class="tip">最多9张图片，第一张为封面</text>
  </view>

  <!-- 表单区域 -->
  <view class="form">
    <input placeholder="商品标题（必填）" bindinput="onInput" data-field="title" value="{{title}}" />
    <view class="picker-wrap">
      <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
        <text class="{{category ? '' : 'placeholder'}}">{{category || '选择分类'}}</text>
      </picker>
    </view>
    <view class="picker-wrap">
      <picker mode="selector" range="{{conditions}}" bindchange="onConditionChange">
        <text class="{{condition ? '' : 'placeholder'}}">{{condition || '选择成色'}}</text>
      </picker>
    </view>
    <input type="digit" placeholder="价格（元）" bindinput="onInput" data-field="price" value="{{price}}" />
    <textarea placeholder="详细描述..." bindinput="onInput" data-field="description" value="{{description}}" />
  </view>

  <button class="submit-btn" bindtap="submitItem" disabled="{{!canSubmit}}">发布</button>
</view>