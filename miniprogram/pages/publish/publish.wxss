.container {
  padding: 30rpx;
}
.title {
  font-size: 38rpx;
  font-weight: bold;
  text-align: center;
  margin: 20rpx 0 40rpx;
}
.image-section {
  margin-bottom: 40rpx;
}
.image-list {
  display: flex;
  flex-wrap: wrap;
}
.image-item {
  width: 200rpx;
  height: 200rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  border-radius: 10rpx;
  overflow: hidden;
}
.image-item image {
  width: 100%;
  height: 100%;
}
.del-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  background: var(--danger);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 44rpx;
  font-size: 28rpx;
}
.add-btn {
  width: 200rpx;
  height: 200rpx;
  background: #f2f2f2;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  font-size: 28rpx;
}
.add-btn text:first-child {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}
.tip {
  color: var(--text-secondary);
  font-size: 24rpx;
  margin-top: 10rpx;
}
.form {
  background: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}
.form input,
.form textarea,
.picker-wrap {
  width: 100%;
  height: 80rpx;
  border-bottom: 1rpx solid var(--border);
  font-size: 30rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
}
.form textarea {
  height: 150rpx;
  padding-top: 20rpx;
}
.placeholder {
  color: #ccc;
}
.submit-btn {
  width: 100%;
  margin-top: 20rpx;
}