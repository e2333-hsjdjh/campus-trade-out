.container { min-height: 100vh; padding: 42rpx 24rpx 54rpx; box-sizing: border-box; }.page-intro { padding: 0 12rpx 28rpx; }.title { display: block; margin-top: 8rpx; font-size: 44rpx; font-weight: 700; letter-spacing: -2rpx; }.subtitle { display: block; margin-top: 8rpx; color: var(--text-secondary); font-size: 25rpx; }.form-card { padding: 28rpx; border-radius: var(--radius-lg); background: var(--card-bg); box-shadow: var(--shadow); }.field-label { display: block; color: var(--text-main); font-size: 28rpx; font-weight: 700; }.field-label text { margin-left: 10rpx; color: var(--text-secondary); font-size: 21rpx; font-weight: 400; }.image-list { display: flex; flex-wrap: wrap; margin-top: 22rpx; }.image-item, .add-btn { width: 142rpx; height: 142rpx; margin: 0 14rpx 14rpx 0; border-radius: 18rpx; }.image-item { position: relative; overflow: hidden; }.image-item image { width: 100%; height: 100%; }.del-btn { position: absolute; top: 8rpx; right: 8rpx; display: flex; width: 38rpx; height: 38rpx; align-items: center; justify-content: center; border-radius: 50%; background: rgba(30,45,39,0.7); color: #fff; }.add-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; border: 2rpx dashed #cbd6ce; background: #f5f8f4; color: var(--brand); font-size: 22rpx; transition: transform 150ms var(--ease-out), background-color 150ms ease; }.add-plus { font-size: 46rpx; line-height: 1; }.form-divider { height: 1rpx; margin: 18rpx 0 26rpx; background: var(--border); }.form-input { height: 90rpx; margin-top: 14rpx; border-bottom: 1rpx solid var(--border); font-size: 30rpx; }.select-row { display: flex; }.picker-wrap { flex: 1; padding: 22rpx 0; border-bottom: 1rpx solid var(--border); }.picker-wrap + .picker-wrap { margin-left: 34rpx; }.picker-label { display: block; margin-bottom: 8rpx; color: var(--text-secondary); font-size: 22rpx; }.picker-wrap picker { color: var(--text-main); font-size: 27rpx; }.placeholder { color: #a8b0aa; }.selected { color: var(--brand); font-weight: 600; }.price-row { display: flex; align-items: center; height: 94rpx; border-bottom: 1rpx solid var(--border); color: var(--coral); font-size: 44rpx; font-weight: 700; }.price-row input { margin-left: 12rpx; font-size: 34rpx; color: var(--text-main); }.description { width: 100%; height: 160rpx; margin-top: 20rpx; font-size: 27rpx; line-height: 1.65; }.submit-btn { width: 100%; height: 94rpx; margin-top: 28rpx; line-height: 94rpx; }
