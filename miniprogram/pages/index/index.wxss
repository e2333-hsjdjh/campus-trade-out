.container { min-height: 100vh; }
.hero { margin: 24rpx 24rpx 12rpx; padding: 34rpx 30rpx 32rpx; border-radius: 36rpx; color: #fdfbf6; background: var(--brand); box-shadow: 0 18rpx 40rpx rgba(27, 67, 53, 0.18); }
.hero-top, .list-heading, .item-meta-row { display: flex; align-items: center; justify-content: space-between; }
.welcome { display: block; margin-top: 8rpx; font-size: 40rpx; font-weight: 700; letter-spacing: -1rpx; }
.search-orb { display: flex; width: 72rpx; height: 72rpx; align-items: center; justify-content: center; border-radius: 50%; background: rgba(255,255,255,0.15); font-size: 52rpx; line-height: 1; transition: transform 150ms var(--ease-out), background-color 150ms ease; }
.search-orb:active { background: rgba(255,255,255,0.24); }
.campus-pill { display: inline-flex; align-items: center; margin-top: 28rpx; padding: 10rpx 16rpx; border-radius: 999rpx; background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.86); font-size: 23rpx; }
.campus-dot { width: 10rpx; height: 10rpx; margin-right: 10rpx; border-radius: 50%; background: var(--accent); }
.hero-copy { margin-top: 30rpx; }
.hero-title { display: block; font-size: 32rpx; font-weight: 600; }
.hero-note { display: block; margin-top: 8rpx; color: rgba(255,255,255,0.66); font-size: 24rpx; }
.item-list { box-sizing: border-box; height: calc(100vh - 388rpx); padding: 28rpx 24rpx 48rpx; }
.list-heading { margin-bottom: 20rpx; }
.list-heading .section-subtitle { display: block; margin-top: 2rpx; }
.refresh-link { padding: 10rpx 4rpx; color: var(--brand); font-size: 25rpx; font-weight: 600; }
.item-card { display: flex; box-sizing: border-box; min-height: 208rpx; margin-bottom: 18rpx; padding: 14rpx; border-radius: var(--radius-lg); background: var(--card-bg); box-shadow: 0 8rpx 26rpx rgba(39,57,48,0.06); transition: transform 150ms var(--ease-out); }
.item-img { width: 180rpx; height: 180rpx; flex: 0 0 auto; margin-right: 22rpx; border-radius: 18rpx; background: #e7e5de; }
.item-info { display: flex; min-width: 0; flex: 1; flex-direction: column; justify-content: space-between; padding: 4rpx 2rpx 4rpx 0; }
.item-tag { padding: 5rpx 12rpx; border-radius: 999rpx; background: var(--brand-soft); color: var(--brand); font-size: 20rpx; font-weight: 700; }
.item-time { color: #9ba59e; font-size: 21rpx; }
.item-title { overflow: hidden; color: var(--text-main); font-size: 31rpx; font-weight: 650; text-overflow: ellipsis; white-space: nowrap; }
.item-price { color: var(--coral); font-size: 38rpx; font-weight: 700; letter-spacing: -1rpx; }
.item-meta { color: var(--text-secondary); font-size: 23rpx; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 130rpx 38rpx 0; text-align: center; }
.empty-mark { display: flex; width: 112rpx; height: 112rpx; align-items: center; justify-content: center; border-radius: 38rpx; background: var(--accent-soft); color: var(--coral); font-size: 54rpx; }
.empty-title { margin-top: 28rpx; color: var(--text-main); font-size: 34rpx; font-weight: 700; }
.empty-text { margin-top: 10rpx; color: var(--text-secondary); font-size: 26rpx; }
.go-publish { width: 350rpx; margin-top: 34rpx; }
.loading, .no-more { padding: 24rpx; color: var(--text-secondary); text-align: center; font-size: 24rpx; }
