.page-shell { min-height: 100vh; background: #f5f6f8; }
.safe-top, .home-header { background: #fff; }
.home-header { padding: 18rpx 24rpx 22rpx; border-bottom: 1rpx solid #f0f1f3; }
.brand-row, .brand-lockup, .school-switch, .search-box, .feed-heading, .goods-bottom, .sheet-heading, .school-row { display: flex; align-items: center; }
.brand-row, .feed-heading, .goods-bottom, .sheet-heading { justify-content: space-between; }
.brand-row { box-sizing: border-box; min-width: 0; }
.brand-lockup { min-width: 0; flex-shrink: 0; }
.brand-mark { display: flex; width: 64rpx; height: 64rpx; align-items: center; justify-content: center; margin-right: 16rpx; border-radius: 20rpx; background: var(--brand); color: #fff; font-size: 30rpx; font-weight: 800; box-shadow: 0 8rpx 20rpx rgba(37,99,235,.2); }
.brand-name, .brand-caption { display: block; }.brand-name { font-size: 31rpx; font-weight: 750; }.brand-caption { margin-top: 1rpx; color: var(--text-secondary); font-size: 20rpx; }
.school-switch { min-width: 0; max-width: 240rpx; margin-left: 16rpx; padding: 14rpx 18rpx; border-radius: 999rpx; background: #f4f6f8; color: #394150; font-size: 24rpx; font-weight: 650; }.school-switch text:first-child { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }.chevron { flex-shrink: 0; margin-left: 7rpx; color: #8b95a5; }
.search-box { height: 76rpx; margin-top: 22rpx; padding-left: 22rpx; border: 2rpx solid #d9e3f7; border-radius: 22rpx; background: #f8faff; }.search-icon { margin-right: 12rpx; color: var(--brand); font-size: 38rpx; }.search-placeholder { min-width: 0; flex: 1; color: #929baa; font-size: 25rpx; }.search-button { align-self: stretch; display: flex; align-items: center; padding: 0 28rpx; border-radius: 0 20rpx 20rpx 0; background: var(--brand); color: #fff; font-size: 25rpx; font-weight: 700; }
.home-scroll { box-sizing: border-box; }
.category-scroll { width: 100%; background: #fff; white-space: nowrap; }.category-row { display: inline-flex; box-sizing: border-box; min-width: 100%; gap: 14rpx; padding: 28rpx 22rpx 26rpx; }.category-item { display: inline-flex; width: 132rpx; flex: 0 0 132rpx; flex-direction: column; align-items: center; color: #3c4350; font-size: 22rpx; }.category-image { width: 108rpx; height: 108rpx; margin-bottom: 11rpx; border-radius: 30rpx; background: #f5f3ef; box-shadow: 0 6rpx 18rpx rgba(38,47,59,.07); transition: transform 150ms var(--ease-out); }.category-item:active .category-image { transform: scale(.94); }
.notice-card { display: flex; align-items: center; margin: 18rpx 22rpx; padding: 22rpx; border: 1rpx solid #dce6fb; border-radius: 22rpx; background: linear-gradient(135deg,#f7faff,#eef4ff); }.notice-badge { padding: 8rpx 12rpx; border-radius: 10rpx; background: var(--brand); color: #fff; font-size: 19rpx; font-weight: 700; }.notice-copy { display: flex; min-width: 0; flex: 1; flex-direction: column; margin-left: 16rpx; }.notice-copy text:first-child { color: #263650; font-size: 26rpx; font-weight: 700; }.notice-copy text:last-child { margin-top: 3rpx; color: #7f8b9d; font-size: 21rpx; }.notice-arrow { color: #8390a5; font-size: 38rpx; }
.feed-heading { padding: 18rpx 24rpx 16rpx; }.feed-title, .feed-subtitle { display: block; }.feed-title { font-size: 36rpx; font-weight: 800; letter-spacing: -1rpx; }.feed-subtitle { margin-top: 2rpx; color: var(--text-secondary); font-size: 22rpx; }.feed-filter { padding: 12rpx 4rpx; color: #657084; font-size: 22rpx; }
.masonry-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14rpx; padding: 0 18rpx; }.goods-card { overflow: hidden; border-radius: 20rpx; background: #fff; box-shadow: 0 6rpx 18rpx rgba(31,35,41,.05); transition: transform 150ms var(--ease-out); }.goods-image { width: 100%; height: 300rpx; background: #e8ebef; }.goods-body { padding: 16rpx 16rpx 18rpx; }.goods-title { display: -webkit-box; overflow: hidden; min-height: 76rpx; color: #252a32; font-size: 27rpx; font-weight: 650; line-height: 1.4; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }.goods-tags { display: flex; gap: 8rpx; margin-top: 12rpx; }.goods-tags text { padding: 4rpx 8rpx; border-radius: 7rpx; background: #f0f4fb; color: #66758d; font-size: 18rpx; }.goods-bottom { min-width: 0; margin-top: 14rpx; }.goods-price { min-width: 0; overflow: hidden; color: #f05a3c; font-size: 34rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }.goods-price text { margin-right: 2rpx; font-size: 20rpx; }.goods-time { flex-shrink: 0; margin-left: 8rpx; color: #a0a7b2; font-size: 19rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 100rpx 30rpx 60rpx; text-align: center; }.empty-symbol { display: flex; width: 104rpx; height: 104rpx; align-items: center; justify-content: center; border-radius: 34rpx; background: #eaf1ff; color: var(--brand); font-size: 30rpx; font-weight: 800; }.empty-title { margin-top: 22rpx; font-size: 32rpx; font-weight: 750; }.empty-copy { margin-top: 8rpx; color: var(--text-secondary); font-size: 24rpx; }.empty-action { width: 250rpx; margin-top: 28rpx; border-radius: 999rpx; background: var(--brand); color: #fff; font-size: 26rpx; }.loading-state, .end-state { padding: 38rpx; color: #9aa3af; text-align: center; font-size: 22rpx; }.bottom-space { height: 44rpx; }
.modal-mask { position: fixed; z-index: 50; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: flex-end; background: rgba(16,24,40,.46); }.school-sheet { box-sizing: border-box; width: 100%; max-height: 76vh; padding: 14rpx 26rpx calc(24rpx + env(safe-area-inset-bottom)); border-radius: 34rpx 34rpx 0 0; background: #fff; animation: sheet-in 240ms var(--ease-out); }.sheet-handle { width: 70rpx; height: 8rpx; margin: 0 auto 24rpx; border-radius: 999rpx; background: #d9dde4; }.sheet-title, .sheet-subtitle { display: block; }.sheet-title { font-size: 38rpx; font-weight: 800; letter-spacing: -1rpx; }.sheet-subtitle { margin-top: 5rpx; color: var(--text-secondary); font-size: 23rpx; }.school-count { padding: 8rpx 13rpx; border-radius: 999rpx; background: var(--brand-soft); color: var(--brand); font-size: 20rpx; font-weight: 700; }.school-search { display: flex; align-items: center; height: 76rpx; margin-top: 24rpx; padding: 0 20rpx; border-radius: 18rpx; background: #f4f6f8; color: #8791a0; }.school-search text { margin-right: 12rpx; font-size: 32rpx; }.school-search input { flex: 1; font-size: 25rpx; }.school-list { max-height: 640rpx; margin-top: 12rpx; }.school-row { min-height: 104rpx; border-bottom: 1rpx solid #eef0f3; }.school-logo { display: flex; width: 64rpx; height: 64rpx; align-items: center; justify-content: center; margin-right: 18rpx; border-radius: 20rpx; background: #eaf1ff; color: var(--brand); font-size: 26rpx; font-weight: 800; }.school-copy { display: flex; flex: 1; flex-direction: column; }.school-copy text:first-child { font-size: 28rpx; font-weight: 700; }.school-copy text:last-child { margin-top: 2rpx; color: #9aa2ae; font-size: 20rpx; }.row-arrow { color: #afb5bf; font-size: 40rpx; }.school-empty { padding: 70rpx 0; color: var(--text-secondary); text-align: center; }.sheet-note { display: block; padding-top: 18rpx; color: #a0a7b2; text-align: center; font-size: 20rpx; }
.goods-tags .demo-tag { background: #fff0e7; color: #cf6535; font-weight: 700; }
@keyframes sheet-in { from { opacity: 0; transform: translateY(100%); } to { opacity: 1; transform: translateY(0); } }
