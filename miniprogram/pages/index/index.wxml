<view class="page-shell">
  <view class="safe-top" style="height: {{statusBarHeight}}px"></view>
  <view class="home-header">
    <view class="brand-row" style="padding-right: {{menuSafeRight}}px">
      <view class="brand-lockup"><view class="brand-mark">集</view><view><text class="brand-name">校园闲置</text><text class="brand-caption">同校好物 · 当面流转</text></view></view>
      <view class="school-switch pressable" bindtap="openSchoolSelector"><text>{{schoolName}}</text><text class="chevron">⌄</text></view>
    </view>
    <view class="search-box pressable" bindtap="goSearch"><text class="search-icon">⌕</text><text class="search-placeholder">搜索教材、数码或宿舍好物</text><view class="search-button">搜索</view></view>
  </view>

  <scroll-view scroll-y class="home-scroll" style="height: calc(100vh - {{statusBarHeight}}px - 214rpx)" bindscrolltolower="loadMore" lower-threshold="120" refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <scroll-view scroll-x enhanced show-scrollbar="{{false}}" class="category-scroll">
      <view class="category-row">
        <view class="category-item pressable" wx:for="{{categories}}" wx:key="key" bindtap="goCategory" data-key="{{item.key}}">
          <image class="category-image" src="{{item.image}}" mode="aspectFill"/><text>{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="notice-card pressable" bindtap="goSafetyGuide">
      <view class="notice-badge">校内限定</view>
      <view class="notice-copy"><text>让闲置留在校园里</text><text>发布真实物品，优先同校面交</text></view>
      <text class="notice-arrow">›</text>
    </view>

    <view class="feed-heading"><view><text class="feed-title">本校好物</text><text class="feed-subtitle">{{schoolName}}同学正在转让</text></view><view class="feed-filter pressable" bindtap="chooseSort">{{sortLabel}}⌄</view></view>

    <view wx:if="{{items.length > 0}}" class="masonry-grid">
      <view class="goods-card pressable" wx:for="{{items}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
        <image class="goods-image" src="{{item.images[0] || ''}}" mode="aspectFill"/>
        <view class="goods-body">
          <text class="goods-title">{{item.title}}</text>
          <view class="goods-tags"><text>{{item.condition}}</text><text>{{item.category}}</text></view>
          <view class="goods-bottom"><text class="goods-price"><text>¥</text>{{item.price}}</text><text class="goods-time">{{item.createTimeFormat}}</text></view>
        </view>
      </view>
    </view>

    <view wx:if="{{!loading && items.length === 0 && selectedSchoolId}}" class="empty-state">
      <view class="empty-symbol">空</view><text class="empty-title">这里还很安静</text><text class="empty-copy">成为 {{schoolName}} 第一个发布闲置的人</text><button class="empty-action" bindtap="goPublish">去发布</button>
    </view>
    <view wx:if="{{loading}}" class="loading-state">正在寻找本校好物...</view>
    <view wx:if="{{!hasMore && items.length > 0}}" class="end-state">已经到底了</view>
    <view class="bottom-space"></view>
  </scroll-view>

  <view wx:if="{{schoolModalVisible}}" class="modal-mask">
    <view class="school-sheet">
      <view class="sheet-handle"></view>
      <view class="sheet-heading"><view><text class="sheet-title">先选择你的学校</text><text class="sheet-subtitle">首页只展示同校同学发布的闲置</text></view><view class="school-count">{{allSchools.length}} 所</view></view>
      <view class="school-search"><text>⌕</text><input value="{{schoolSearchKey}}" bindinput="onSearchSchool" placeholder="搜索学校名称"/></view>
      <scroll-view scroll-y class="school-list">
        <view class="school-row pressable" wx:for="{{filteredSchools}}" wx:key="id" bindtap="selectSchool" data-id="{{item.id}}">
          <view class="school-logo">校</view><view class="school-copy"><text>{{item.name}}</text><text>进入专属校园圈</text></view><text class="row-arrow">›</text>
        </view>
        <view wx:if="{{filteredSchools.length === 0}}" class="school-empty">暂未找到这所学校</view>
      </scroll-view>
      <text class="sheet-note">选择后仍可浏览；发布、私聊等操作需要登录</text>
    </view>
  </view>
</view>
