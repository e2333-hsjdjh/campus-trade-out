<view class="container">
  <view class="hero">
    <view class="hero-top">
      <view>
        <text class="eyebrow">CAMPUS FLEA MARKET</text>
        <text class="welcome">{{greeting}}，{{nickName}}</text>
      </view>
      <view class="search-orb pressable" bindtap="goSearch">
        <text>⌕</text>
      </view>
    </view>
    <view class="campus-pill"><text class="campus-dot"></text><text>{{schoolName}} · 只看熟人圈</text></view>
    <view class="hero-copy">
      <text class="hero-title">让好物，继续在校园里流转。</text>
      <text class="hero-note">淘一本书，也认识一个有趣的人。</text>
    </view>
  </view>

  <scroll-view
    scroll-y
    class="item-list"
    bindscrolltolower="loadMore"
    lower-threshold="100"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="list-heading" wx:if="{{items.length > 0}}">
      <view><text class="section-title">正在流转</text><text class="section-subtitle">本校同学的闲置好物</text></view>
      <view class="refresh-link pressable" bindtap="onRefresh">换一批</view>
    </view>
    <block wx:if="{{items.length > 0}}">
      <view
        class="item-card pressable"
        wx:for="{{items}}"
        wx:key="_id"
        bindtap="goDetail"
        data-id="{{item._id}}"
      >
        <image src="{{item.images[0] || ''}}" mode="aspectFill" class="item-img" />
        <view class="item-info">
          <view class="item-meta-row"><text class="item-tag">{{item.category}}</text><text class="item-time">{{item.createTimeFormat}}</text></view>
          <text class="item-title">{{item.title}}</text>
          <text class="item-price">¥{{item.price}}</text>
          <text class="item-meta">{{item.condition}} · 同校自取优先</text>
        </view>
      </view>
    </block>

    <view wx:if="{{!loading && items.length === 0}}" class="empty">
      <view class="empty-mark">✦</view>
      <text class="empty-title">等一件好物出现</text>
      <text class="empty-text">你的校园圈还没有人发布闲置。</text>
      <button class="btn-primary go-publish" bindtap="goPublish">发布第一件好物</button>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{!hasMore && items.length > 0}}" class="no-more">— 没有更多了 —</view>
  </scroll-view>
</view>
