<view class="container">
  <view class="header">
    <view class="header-top">
      <text class="welcome">{{greeting}}，{{nickName}}</text>
      <text class="search-icon" bindtap="goSearch">🔍</text>
    </view>
    <text class="school">📍 {{schoolName}}</text>
  </view>

  <scroll-view
    scroll-y
    class="item-list"
    bindscrolltolower="loadMore"
    lower-threshold="100"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <block wx:if="{{items.length > 0}}">
      <view
        class="card item-card"
        wx:for="{{items}}"
        wx:key="_id"
        bindtap="goDetail"
        data-id="{{item._id}}"
      >
        <image src="{{item.images[0] || ''}}" mode="aspectFill" class="item-img" />
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <text class="item-price">¥{{item.price}}</text>
          <text class="item-meta">{{item.category}} · {{item.condition}}</text>
          <text class="item-time">{{item.createTimeFormat}}</text>
        </view>
      </view>
    </block>

    <view wx:if="{{!loading && items.length === 0}}" class="empty">
      <text class="empty-icon">📦</text>
      <text class="empty-text">本校还没有商品，快去发布吧！</text>
      <button class="btn-primary go-publish" bindtap="goPublish">去发布</button>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{!hasMore && items.length > 0}}" class="no-more">— 没有更多了 —</view>
  </scroll-view>
</view>