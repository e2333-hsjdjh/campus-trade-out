.mine-page { box-sizing: border-box; min-height: 100vh; padding-bottom: 48rpx; background: #f5f6f8; }.safe-top, .mine-nav { background: #fff; }.mine-nav { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 28rpx 24rpx; }.mine-nav > text { font-size: 40rpx; font-weight: 850; letter-spacing: -1rpx; }.nav-action { padding: 12rpx 4rpx; color: #667084; font-size: 24rpx; }
.profile-card { display: flex; align-items: center; padding: 28rpx 26rpx 30rpx; background: #fff; transition: transform 150ms var(--ease-out); }.avatar { width: 124rpx; height: 124rpx; flex: 0 0 auto; margin-right: 20rpx; border: 4rpx solid #e6edfb; border-radius: 50%; background: #edf1f6; }.profile-main { display: flex; min-width: 0; flex: 1; flex-direction: column; }.nickname { overflow: hidden; font-size: 35rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }.school-line { margin-top: 6rpx; color: #737d8c; font-size: 22rpx; }.identity-tags { display: flex; gap: 8rpx; margin-top: 12rpx; }.identity-tags text { padding: 5rpx 10rpx; border-radius: 7rpx; background: #eef4ff; color: #4c6fa9; font-size: 18rpx; }.home-link { align-self: flex-start; margin-top: 7rpx; color: #667084; font-size: 21rpx; }
.stats-card { display: flex; align-items: center; margin: 18rpx 20rpx 0; padding: 24rpx 0; border-radius: 22rpx; background: linear-gradient(135deg,#263a5c,#315b99); color: #fff; box-shadow: 0 12rpx 30rpx rgba(38,58,92,.16); }.stats-card > view:not(.divider) { display: flex; flex: 1; flex-direction: column; align-items: center; }.stats-card > view text:first-child { font-size: 35rpx; font-weight: 850; }.stats-card > view text:last-child { margin-top: 2rpx; color: rgba(255,255,255,.68); font-size: 20rpx; }.stats-card .divider { width: 1rpx; height: 48rpx; background: rgba(255,255,255,.18); }
.section-card, .menu-card { margin: 18rpx 20rpx 0; overflow: hidden; border-radius: 22rpx; background: #fff; box-shadow: 0 5rpx 18rpx rgba(31,35,41,.04); }.section-heading { display: flex; align-items: baseline; justify-content: space-between; padding: 25rpx 24rpx 8rpx; }.section-heading text:first-child { font-size: 29rpx; font-weight: 800; }.section-heading text:last-child { color: #9aa2ae; font-size: 20rpx; }.quick-grid { display: grid; grid-template-columns: repeat(4, 1fr); padding: 20rpx 8rpx 28rpx; }.quick-item { display: flex; min-width: 0; flex-direction: column; align-items: center; }.quick-icon { display: flex; width: 68rpx; height: 68rpx; align-items: center; justify-content: center; margin-bottom: 10rpx; border-radius: 22rpx; font-size: 24rpx; font-weight: 850; }.quick-item > text:nth-child(2) { font-size: 22rpx; font-weight: 700; }.quick-item > text:last-child { margin-top: 3rpx; color: #9ba3af; font-size: 17rpx; }.blue { background: #eaf1ff; color: #3975d4; }.green { background: #e7f7ed; color: #358c59; }.orange { background: #fff0df; color: #d77727; }.violet { background: #f0edff; color: #7060cf; }
.menu-row { display: flex; align-items: center; min-height: 112rpx; padding: 0 22rpx; border-bottom: 1rpx solid #eef0f3; }.menu-row:last-child { border-bottom: 0; }.menu-symbol { display: flex; width: 62rpx; height: 62rpx; align-items: center; justify-content: center; margin-right: 16rpx; border-radius: 20rpx; font-size: 23rpx; font-weight: 850; }.shield { background: #e8f6ee; color: #348456; }.profile { background: #edf3ff; color: #426fb8; }.logout { background: #fff0ed; color: #d7644f; }.menu-copy { display: flex; flex: 1; flex-direction: column; }.menu-copy text:first-child { font-size: 26rpx; font-weight: 700; }.menu-copy text:last-child { margin-top: 3rpx; color: #969fab; font-size: 20rpx; }.arrow { color: #b2b8c1; font-size: 38rpx; }.mine-footer { display: block; padding: 34rpx 0 8rpx; color: #a6adb7; text-align: center; font-size: 20rpx; }
