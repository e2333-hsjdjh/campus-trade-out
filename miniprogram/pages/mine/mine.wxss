.container { min-height: 100vh; padding-bottom: 50rpx; }.profile-hero { margin: 24rpx; padding: 32rpx; border-radius: 34rpx; background: var(--brand); color: #fffdf8; box-shadow: 0 18rpx 38rpx rgba(27,67,53,0.18); }.profile-top { display: flex; align-items: center; }.avatar { width: 116rpx; height: 116rpx; margin-right: 20rpx; border: 4rpx solid rgba(255,255,255,0.42); border-radius: 50%; background: var(--brand-soft); }.nickname { display: block; font-size: 38rpx; font-weight: 700; letter-spacing: -1rpx; }.school-pill { display: inline-flex; align-items: center; margin-top: 10rpx; padding: 7rpx 12rpx; border-radius: 999rpx; background: rgba(255,255,255,0.13); color: rgba(255,255,255,0.78); font-size: 22rpx; }.pill-dot { width: 8rpx; height: 8rpx; margin-right: 8rpx; border-radius: 50%; background: var(--accent); }.profile-note { display: block; margin-top: 28rpx; color: rgba(255,255,255,0.65); font-size: 25rpx; }.menu-card { margin: 28rpx 24rpx 0; border-radius: var(--radius-lg); overflow: hidden; background: var(--card-bg); box-shadow: var(--shadow); }.menu-item { display: flex; align-items: center; min-height: 122rpx; padding: 0 24rpx; border-bottom: 1rpx solid var(--border); transition: transform 150ms var(--ease-out), background-color 150ms ease; }.menu-item:last-child { border-bottom: 0; }.menu-icon { display: flex; width: 64rpx; height: 64rpx; align-items: center; justify-content: center; margin-right: 18rpx; border-radius: 20rpx; font-size: 32rpx; font-weight: 700; }.warm { background: var(--accent-soft); color: #ab7127; }.green { background: var(--brand-soft); color: var(--brand); }.peach { background: #f9e4dd; color: var(--coral); }.menu-text { display: flex; flex: 1; flex-direction: column; }.menu-text text:first-child { font-size: 29rpx; font-weight: 700; }.menu-text text:last-child { margin-top: 3rpx; color: var(--text-secondary); font-size: 22rpx; }.arrow { color: #a8b0aa; font-size: 40rpx; }.footer-note { display: block; margin-top: 38rpx; color: #a0aaa3; text-align: center; font-size: 22rpx; }
