.container { min-height: 100vh; padding: 42rpx 24rpx; box-sizing: border-box; }.page-head { padding: 0 12rpx 26rpx; }.title { display: block; margin-top: 8rpx; font-size: 42rpx; font-weight: 700; letter-spacing: -2rpx; }.subtitle { display: block; margin-top: 7rpx; color: var(--text-secondary); font-size: 24rpx; }.item-card { display: flex; align-items: center; min-height: 172rpx; margin-bottom: 16rpx; padding: 12rpx; border-radius: 22rpx; background: var(--card-bg); box-shadow: 0 8rpx 24rpx rgba(39,57,48,0.05); }.item-img { width: 128rpx; height: 128rpx; margin-right: 18rpx; border-radius: 16rpx; background: #e6e7e1; }.item-info { display: flex; min-width: 0; flex: 1; flex-direction: column; justify-content: space-between; }.item-status { align-self: flex-start; padding: 3rpx 10rpx; border-radius: 999rpx; background: var(--brand-soft); color: var(--brand); font-size: 19rpx; font-weight: 700; }.item-title { overflow: hidden; margin-top: 6rpx; font-size: 28rpx; font-weight: 650; text-overflow: ellipsis; white-space: nowrap; }.item-price { margin-top: 5rpx; color: var(--coral); font-size: 31rpx; font-weight: 700; }.actions { display: flex; flex-direction: column; margin-left: 10rpx; }.actions button { width: 76rpx; margin: 0; padding: 7rpx 0; border-radius: 12rpx; font-size: 20rpx; line-height: 1.35; }.actions button + button { margin-top: 6rpx; }.edit-button { background: #edf3f8; color: #315d78; }.sold-button { background: var(--brand-soft); color: var(--brand); }.delist-button { background: #f7ece8; color: var(--coral); }.empty { display: flex; flex-direction: column; align-items: center; margin-top: 180rpx; color: var(--text-secondary); text-align: center; font-size: 25rpx; }.empty-mark { display: flex; width: 100rpx; height: 100rpx; align-items: center; justify-content: center; margin-bottom: 22rpx; border-radius: 32rpx; background: var(--accent-soft); color: var(--coral); font-size: 48rpx; }.empty-title { margin-bottom: 8rpx; color: var(--text-main); font-size: 33rpx; font-weight: 700; }
