.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.item-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
}
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.item-info text {
  font-size: 28rpx;
}
.actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-left: 20rpx;
}
.actions button {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
}
.empty {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
}