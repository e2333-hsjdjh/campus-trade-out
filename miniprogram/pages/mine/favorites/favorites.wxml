<view class="favorites-page">
  <view class="page-head"><text class="eyebrow">SAVED FOR LATER</text><text class="title">我的收藏</text><text class="subtitle">把感兴趣的同校好物先收在这里。</text></view>
  <view wx:if="{{items.length > 0}}" class="favorite-list">
    <view class="favorite-card pressable" wx:for="{{items}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <image class="item-image" src="{{item.images[0] || ''}}" mode="aspectFill"/>
      <view class="item-copy">
        <view class="status-row"><text class="status {{item.status === '在售' ? 'selling' : 'inactive'}}">{{item.status}}</text><text>{{item.favoriteTimeFormat}}</text></view>
        <text class="item-title">{{item.title}}</text>
        <view class="item-meta"><text>¥{{item.price}}</text><text>{{item.condition}} · {{item.category}}</text></view>
      </view>
      <view
        class="remove-button pressable {{removingId ? 'is-disabled' : ''}}"
        role="button"
        aria-label="取消收藏"
        catchtap="removeFavorite"
        data-id="{{item._id}}"
      >{{removingId === item._id ? '…' : '取消'}}</view>
    </view>
    <view wx:if="{{loading}}" class="list-note">正在加载更多...</view>
    <view wx:elif="{{!hasMore}}" class="list-note">已经看完全部收藏</view>
  </view>
  <view wx:elif="{{loading}}" class="state-page"><view class="state-mark">藏</view><text>正在加载收藏...</text></view>
  <view wx:else class="state-page"><view class="state-mark">藏</view><text class="state-title">还没有收藏商品</text><text>遇到感兴趣的同校好物，可以先收藏再慢慢决定。</text><button bindtap="goHome">去首页看看</button></view>
</view>
