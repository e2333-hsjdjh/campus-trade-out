.favorites-page { box-sizing: border-box; min-height: 100vh; padding: 40rpx 22rpx 60rpx; background: #f5f6f8; }.page-head { padding: 0 10rpx 26rpx; }.title { display: block; margin-top: 7rpx; font-size: 42rpx; font-weight: 800; letter-spacing: -1rpx; }.subtitle { display: block; margin-top: 7rpx; color: var(--text-secondary); font-size: 23rpx; }.favorite-card { display: flex; position: relative; align-items: center; min-height: 176rpx; margin-bottom: 15rpx; padding: 14rpx; border-radius: 22rpx; background: #fff; box-shadow: 0 6rpx 20rpx rgba(31,35,41,.05); }.item-image { width: 148rpx; height: 148rpx; flex: 0 0 auto; margin-right: 18rpx; border-radius: 17rpx; background: #e9ecf0; }.item-copy { display: flex; min-width: 0; flex: 1; flex-direction: column; align-self: stretch; justify-content: space-between; padding: 3rpx 0; }.status-row, .item-meta { display: flex; align-items: center; justify-content: space-between; }.status-row > text:last-child { padding-right: 88rpx; color: #a0a7b1; font-size: 18rpx; }.status { padding: 4rpx 9rpx; border-radius: 999rpx; font-size: 18rpx; font-weight: 700; }.status.selling { background: #e9f7ee; color: #38865a; }.status.inactive { background: #f0f1f3; color: #747d89; }.item-title { overflow: hidden; color: #252b34; font-size: 27rpx; font-weight: 750; text-overflow: ellipsis; white-space: nowrap; }.item-meta > text:first-child { color: #ef5d42; font-size: 31rpx; font-weight: 800; }.item-meta > text:last-child { color: #8c96a3; font-size: 19rpx; }.remove-button { position: absolute; top: 14rpx; right: 14rpx; display: flex; width: 76rpx; height: 44rpx; align-items: center; justify-content: center; border: 1rpx solid #e5e9ef; border-radius: 999rpx; background: #f7f8fa; color: #697586; font-size: 18rpx; font-weight: 650; line-height: 1; transition: transform 140ms var(--ease-out), opacity 140ms ease; }.remove-button.is-disabled { opacity: .55; }.list-note { padding: 24rpx; color: #9aa3af; text-align: center; font-size: 20rpx; }.state-page { display: flex; flex-direction: column; align-items: center; padding: 190rpx 40rpx 0; color: #8c96a3; text-align: center; font-size: 23rpx; line-height: 1.6; }.state-mark { display: flex; width: 104rpx; height: 104rpx; align-items: center; justify-content: center; margin-bottom: 21rpx; border-radius: 34rpx; background: #eaf1ff; color: var(--brand); font-size: 29rpx; font-weight: 800; }.state-title { margin-bottom: 5rpx; color: #29313c; font-size: 31rpx; font-weight: 800; }.state-page button { display: flex; height: 76rpx; align-items: center; justify-content: center; margin-top: 25rpx; padding: 0 34rpx; border-radius: 999rpx; background: var(--brand); color: #fff; font-size: 23rpx; font-weight: 650; line-height: 1.2; }
