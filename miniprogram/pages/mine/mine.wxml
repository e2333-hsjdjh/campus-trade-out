<view class="mine-page">
  <view class="safe-top" style="height: {{statusBarHeight}}px"></view>
  <view class="mine-nav"><text>我的</text><view class="nav-action pressable" bindtap="goEditProfile">设置</view></view>

  <view class="profile-card pressable" bindtap="goUserHome">
    <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
    <view class="profile-main"><text class="nickname">{{userInfo.nickName || '校园同学'}}</text><text class="school-line">{{schoolName}} · 已认证校园</text><view class="identity-tags"><text>同校交易</text><text>信用资料</text></view></view>
    <view class="home-link">个人主页 ›</view>
  </view>

  <view class="stats-card">
    <view><text>{{stats.total}}</text><text>累计发布</text></view><view class="divider"></view>
    <view><text>{{stats.selling}}</text><text>正在出售</text></view><view class="divider"></view>
    <view><text>{{stats.sold}}</text><text>已经售出</text></view>
  </view>

  <view class="section-card">
    <view class="section-heading"><text>我的交易</text><text>管理闲置与沟通</text></view>
    <view class="quick-grid">
      <view class="quick-item pressable" bindtap="goMyItems"><view class="quick-icon blue">单</view><text>我的发布</text><text>{{stats.selling}} 件在售</text></view>
      <view class="quick-item pressable" bindtap="goChatList"><view class="quick-icon green">聊</view><text>商品消息</text><text>继续沟通</text></view>
      <view class="quick-item pressable" bindtap="goUserHome"><view class="quick-icon orange">页</view><text>个人主页</text><text>查看展示页</text></view>
      <view class="quick-item pressable" bindtap="goEditProfile"><view class="quick-icon violet">编</view><text>编辑资料</text><text>头像与昵称</text></view>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-row pressable" bindtap="showSafetyGuide"><view class="menu-symbol shield">安</view><view class="menu-copy"><text>安全交易指南</text><text>校内面交与防骗提醒</text></view><text class="arrow">›</text></view>
    <view class="menu-row pressable" bindtap="goEditProfile"><view class="menu-symbol profile">资</view><view class="menu-copy"><text>账号与个人资料</text><text>管理昵称、头像和联系方式</text></view><text class="arrow">›</text></view>
    <view class="menu-row pressable" bindtap="logout"><view class="menu-symbol logout">退</view><view class="menu-copy"><text>退出登录</text><text>保留当前学校浏览选择</text></view><text class="arrow">›</text></view>
  </view>
  <text class="mine-footer">校园闲置 · 只让真实好物继续流转</text>
</view>
