<!--pages/chat/chat.wxml-->
<text>pages/chat/chat.wxml</text>
<view class="container">
  <!-- 顶部提示条 -->
  <view class="notice">
    达成意向后可交换微信号，注意交易安全。
  </view>

  <!-- 消息列表 -->
  <scroll-view
    scroll-y
    class="msg-list"
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    bindscrolltoupper="loadMore"
    upper-threshold="50"
  >
    <view wx:if="{{loadingMore}}" class="loading-more">加载更多...</view>
    <block wx:for="{{messages}}" wx:key="_id">
      <view class="msg-item {{item.senderOpenid === myOpenid ? 'mine' : 'other'}}" id="msg-{{item._id}}">
        <text class="msg-content">{{item.content}}</text>
        <text class="msg-time">{{item.createTimeFormat}}</text>
      </view>
    </block>
  </scroll-view>

  <!-- 底部输入框 -->
  <view class="input-bar">
    <input
      placeholder="输入消息..."
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="sendMsg"
      confirm-type="send"
    />
    <button bindtap="sendMyWechat">发送微信号</button>
  </view>
</view>