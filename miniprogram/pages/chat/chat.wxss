.container { display: flex; height: 100vh; flex-direction: column; background: var(--bg); }.notice { display: flex; align-items: center; padding: 16rpx 26rpx; background: var(--accent-soft); color: #876027; font-size: 22rpx; }.notice-dot { width: 10rpx; height: 10rpx; margin-right: 10rpx; border-radius: 50%; background: var(--coral); }.msg-list { box-sizing: border-box; flex: 1; padding: 28rpx 24rpx; }.loading-more { padding-bottom: 20rpx; color: var(--text-secondary); text-align: center; font-size: 22rpx; }.chat-empty { margin-top: 200rpx; color: #9aa39c; text-align: center; font-size: 25rpx; }.msg-item { display: flex; flex-direction: column; margin-bottom: 24rpx; }.msg-item.mine { align-items: flex-end; }.msg-item.other { align-items: flex-start; }.msg-content { max-width: 72%; padding: 16rpx 20rpx; border-radius: 20rpx 20rpx 20rpx 6rpx; background: var(--card-bg); color: var(--text-main); box-shadow: 0 5rpx 16rpx rgba(39,57,48,0.05); font-size: 29rpx; line-height: 1.5; word-break: break-all; }.mine .msg-content { border-radius: 20rpx 20rpx 6rpx 20rpx; background: var(--brand); color: #fff; box-shadow: none; }.msg-time { margin-top: 6rpx; color: #a2aaa4; font-size: 20rpx; }.input-bar { display: flex; align-items: center; padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid var(--border); background: #fffdf9; }.input-bar input { flex: 1; height: 70rpx; padding: 0 22rpx; border-radius: 18rpx; background: #f0f2ed; font-size: 27rpx; }.wechat-action { margin-left: 14rpx; padding: 15rpx 16rpx; border-radius: 16rpx; background: var(--brand-soft); color: var(--brand); font-size: 22rpx; font-weight: 700; transition: transform 150ms var(--ease-out); }
