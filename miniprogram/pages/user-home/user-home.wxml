<view class="profile-page">
  <view class="profile-hero">
    <view class="safe-top" style="height: {{statusBarHeight}}px"></view>
    <view class="hero-nav"><view class="back pressable" bindtap="goBack">‹</view><text>我的个人主页</text><view class="edit pressable" bindtap="goEditProfile">编辑</view></view>
    <view class="identity-row">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"/>
      <view class="identity-copy"><text class="nickname">{{userInfo.nickName || '校园同学'}}</text><text class="school">{{schoolName}} · 校园身份已认证</text><view class="level">校园卖家</view></view>
    </view>
    <text class="bio">认真描述每件闲置，也认真对待每一次同校交易。</text>
    <view class="hero-stats"><view><text>{{stats.total}}</text><text>发布</text></view><view><text>{{stats.selling}}</text><text>在售</text></view><view><text>{{stats.sold}}</text><text>售出</text></view><button bindtap="goEditProfile">编辑资料</button></view>
  </view>

  <view class="profile-content">
    <view class="tabs"><view class="{{activeTab === '在售' ? 'active' : ''}}" bindtap="changeTab" data-tab="在售">在售好物</view><view class="{{activeTab === '已售' ? 'active' : ''}}" bindtap="changeTab" data-tab="已售">已售记录</view><view class="{{activeTab === '全部' ? 'active' : ''}}" bindtap="changeTab" data-tab="全部">全部发布</view></view>
    <scroll-view scroll-y class="items-scroll">
      <view wx:if="{{visibleItems.length > 0}}" class="items-grid">
        <view class="profile-item pressable" wx:for="{{visibleItems}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
          <view class="image-wrap"><image src="{{item.images[0] || ''}}" mode="aspectFill"/><text>{{item.status}}</text></view>
          <text class="item-title">{{item.title}}</text><view class="item-bottom"><text>¥{{item.price}}</text><text>{{item.createTimeFormat}}</text></view>
        </view>
      </view>
      <view wx:else class="empty"><view>闲</view><text>这个分类还没有发布记录</text><button bindtap="goEditProfile">完善个人资料</button></view>
      <view class="bottom-space"></view>
    </scroll-view>
  </view>
</view>
