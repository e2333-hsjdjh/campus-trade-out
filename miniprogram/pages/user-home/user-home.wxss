.profile-page { min-height: 100vh; background: #eef1f5; }.profile-hero { min-height: 590rpx; color: #fff; background: linear-gradient(145deg,#29466f 0%,#506fa1 50%,#7e89ac 100%); }.hero-nav { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 26rpx; }.hero-nav > text { color: rgba(255,255,255,.8); font-size: 23rpx; }.back { display: flex; width: 60rpx; height: 60rpx; align-items: center; justify-content: center; font-size: 60rpx; font-weight: 300; }.edit { padding: 12rpx; font-size: 23rpx; }.identity-row { display: flex; align-items: center; padding: 58rpx 32rpx 0; }.avatar { width: 144rpx; height: 144rpx; margin-right: 24rpx; border: 5rpx solid rgba(255,255,255,.72); border-radius: 50%; background: #dce3ef; }.identity-copy { display: flex; flex: 1; flex-direction: column; }.nickname { font-size: 39rpx; font-weight: 850; }.school { margin-top: 8rpx; color: rgba(255,255,255,.7); font-size: 22rpx; }.level { align-self: flex-start; margin-top: 13rpx; padding: 5rpx 12rpx; border-radius: 999rpx; background: rgba(255,255,255,.16); color: #fff; font-size: 19rpx; }.bio { display: block; padding: 42rpx 34rpx 0; color: rgba(255,255,255,.82); font-size: 24rpx; }.hero-stats { display: flex; align-items: center; padding: 34rpx 32rpx 38rpx; }.hero-stats > view { display: flex; width: 100rpx; flex-direction: column; }.hero-stats > view text:first-child { font-size: 30rpx; font-weight: 800; }.hero-stats > view text:last-child { color: rgba(255,255,255,.62); font-size: 19rpx; }.hero-stats button { width: 190rpx; height: 66rpx; margin: 0 0 0 auto; border: 1rpx solid rgba(255,255,255,.7); border-radius: 999rpx; background: rgba(255,255,255,.08); color: #fff; font-size: 23rpx; line-height: 66rpx; }
.profile-content { position: relative; z-index: 2; overflow: hidden; margin-top: -26rpx; border-radius: 30rpx 30rpx 0 0; background: #fff; }.tabs { display: flex; height: 96rpx; align-items: center; padding: 0 26rpx; border-bottom: 1rpx solid #edf0f3; }.tabs view { position: relative; margin-right: 52rpx; color: #707987; font-size: 26rpx; }.tabs view.active { color: #202734; font-weight: 800; }.tabs view.active::after { position: absolute; right: 0; bottom: -25rpx; left: 0; height: 6rpx; border-radius: 999rpx; background: var(--brand); content: ''; }.items-scroll { box-sizing: border-box; height: calc(100vh - 660rpx); padding: 18rpx; background: #f7f8fa; }.items-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 14rpx; }.profile-item { overflow: hidden; border-radius: 18rpx; background: #fff; }.image-wrap { position: relative; }.image-wrap image { width: 100%; height: 290rpx; background: #e9ebef; }.image-wrap text { position: absolute; right: 10rpx; bottom: 10rpx; padding: 5rpx 10rpx; border-radius: 8rpx; background: rgba(19,26,38,.72); color: #fff; font-size: 18rpx; }.item-title { display: -webkit-box; overflow: hidden; min-height: 72rpx; padding: 14rpx 14rpx 0; font-size: 25rpx; font-weight: 700; line-height: 1.4; -webkit-box-orient: vertical; -webkit-line-clamp: 2; }.item-bottom { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 14rpx 16rpx; }.item-bottom text:first-child { color: #ef5e43; font-size: 30rpx; font-weight: 800; }.item-bottom text:last-child { color: #a0a7b2; font-size: 18rpx; }.empty { display: flex; flex-direction: column; align-items: center; padding: 100rpx 20rpx; color: #8e97a4; }.empty > view { display: flex; width: 100rpx; height: 100rpx; align-items: center; justify-content: center; border-radius: 32rpx; background: #eaf1ff; color: var(--brand); font-size: 30rpx; font-weight: 800; }.empty > text { margin-top: 20rpx; font-size: 24rpx; }.empty button { margin-top: 25rpx; border-radius: 999rpx; background: #fff; color: var(--brand); font-size: 23rpx; }.bottom-space { height: 40rpx; }
