page {
  --brand: #2563eb;
  --brand-deep: #1d4ed8;
  --brand-soft: #eff6ff;
  --accent: #ffb020;
  --accent-soft: #fff7e6;
  --coral: #f97316;
  --danger: #e5484d;
  --bg: #f6f7f9;
  --card-bg: #ffffff;
  --text-main: #1f2329;
  --text-secondary: #86909c;
  --border: #e5e6eb;
  --shadow: 0 8rpx 26rpx rgba(31, 35, 41, 0.06);
  --radius-lg: 20rpx;
  --radius-md: 14rpx;
  --ease-out: cubic-bezier(0.23, 1, 0.32, 1);

  background: var(--bg);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.45;
}

button::after { border: 0; }

.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
}

.btn-primary,
.button-primary {
  background: var(--brand);
  color: #fffdf8;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  transition: transform 150ms var(--ease-out), background-color 150ms ease;
}

.btn-primary:active,
.button-primary:active,
.pressable:active {
  transform: scale(0.97);
}

.btn-primary[disabled] {
  background: #b9c1bb;
  color: rgba(255, 255, 255, 0.78);
}

.eyebrow {
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.section-title {
  color: var(--text-main);
  font-size: 38rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.section-subtitle {
  color: var(--text-secondary);
  font-size: 24rpx;
}
