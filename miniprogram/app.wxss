/* 全局颜色变量 */
page {
  --primary: #07c160;
  --danger: #e74c3c;
  --bg: #f5f5f5;
  --card-bg: #ffffff;
  --text-main: #333333;
  --text-secondary: #888888;
  --border: #eeeeee;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text-main);
  font-size: 28rpx;
}

/* 通用卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 通用按钮 */
.btn-primary {
  background: var(--primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
}
.btn-primary[disabled] {
  background: #ccc;
}